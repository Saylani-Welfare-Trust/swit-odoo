<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pos_direct_deposit_view_tree" model="ir.ui.view">
        <field name="name">direct.deposit.view.tree</field>
        <field name="model">direct.deposit</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" edit="0">
                <field name="state" column_invisible="1" />
                <field name="name" readonly="1" />
                <field name="donor_id" string="Donor" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                <field name="amount" readonly="state in ['clear']" />
                <field name="analytic_account_id" string="Branch" readonly="1" />
                <field name="bank_id" string="Bank Deposit" readonly="state in ['clear']" />
                <field name="user_id" string="Created By" readonly="1" />
                <field name="create_date" string="Created On" readonly="1"  />
                <field name="transaction_ref" readonly="1"  />
                <field name="state" optional="show" widget="badge" decoration-warning="state == 'draft'" decoration-info="state == 'not_clear'" decoration-success="state == 'clear'" />
            </tree>
        </field>
    </record>


    <record id="pos_direct_deposit_action" model="ir.actions.act_window">
        <field name="name">Direct Deposit</field>
        <field name="res_model">direct.deposit</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('user_id', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for direct depsoit records....
            </p>
        </field>
        <field name="view_ids"
            eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('bn_direct_deposit.pos_direct_deposit_view_tree')})]"/>
    </record>

    <menuitem
        id="pos_direct_deposit_menu"
        name="Direct Deposit"
        action="pos_direct_deposit_action"
        parent="point_of_sale.menu_point_rep"
        sequence="10"/>

</odoo>
