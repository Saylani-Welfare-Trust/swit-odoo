<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <!-- ===================== -->
        <!-- Direct Deposit Receipt -->
        <!-- ===================== -->
        <template id="bn_direct_deposit.direct_deposit_receipt_template_duplicate">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <!-- PAGE WRAPPER -->
                        <div class="page" style="position:relative;">
                            <!-- ===== STYLES ===== -->
                            <style>
                                body {
                                    font-family: Arial, sans-serif;
                                    font-size: 11px;
                                }

                                h1 {
                                    font-size: 14px;
                                    font-weight: bold;
                                    margin: 2px 0;
                                }

                                h4 {
                                    font-size: 12px;
                                    margin: 6px 0;
                                    font-weight: bold;
                                }

                                table {
                                    font-size: 11px;
                                    border-collapse: collapse;
                                }

                                th, td {
                                    padding: 3px 4px !important;
                                }

                                /* ✅ FIXED WATERMARK */
                                .watermark {
                                    position: absolute; /* was fixed */
                                    top: 420px;         /* adjust if needed */
                                    left: 50%;
                                    transform: translateX(-50%) rotate(-30deg);
                                    font-size: 80px;
                                    color: rgba(200, 200, 200, 0.15);
                                    font-weight: bold;
                                    white-space: nowrap;
                                    pointer-events: none;
                                    z-index: 0;
                                }
                            </style>

                            <img t-if="o.env.company.dn_image"
                                t-att-src="image_data_uri(o.env.company.dn_image)"
                                style="height: 100%; width: 100%;"/>

                            <!-- ===== WATERMARK ===== -->
                            <div class="watermark">Duplicate</div>

                            <!-- ===== HEADER ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <h1>Provisional Receipt</h1>
                                </div>
                                <div class="col-6 text-end">
                                    <h1>
                                        Saylani Welfare International Trust<br/>
                                        <t t-if="o.user_id.employee_id.analytic_account_id">
                                        <br/>
                                        (<t t-esc="o.user_id.employee_id.analytic_account_id.name"/>)
                                        </t>
                                    </h1>
                                </div>
                            </div>

                            <hr style="margin:4px 0"/>

                            <!-- ===== BASIC INFO ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <div><strong>DD #:</strong> <t t-esc="o.name or '--'"/></div>
                                    <div><strong>Donor Name:</strong> <t t-esc="o.donor_id.name or '-'"/></div>
                                    <div><strong>CNIC No.:</strong> <t t-esc="o.donor_id.cnic_no or '-'"/></div>
                                    <div><strong>Transaction No.:</strong> <t t-esc="o.transaction_ref or ''"/></div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date:</strong>
                                        <t t-esc="o.create_date.strftime('%d-%m-%Y %H:%M') if o.create_date else '--'"/>
                                    </div>
                                    <div>
                                        <strong>Bank Deposit:</strong>
                                        <t t-esc="o.bank_id.name"/>
                                    </div>
                                    <div>
                                        <strong>Contact No.:</strong>
                                        <t t-esc="o.mobile or '-'"/>
                                    </div>
                                    <div>
                                        <strong>Total Amount:</strong>
                                        <t t-esc="'{:,}'.format(int(o.amount) or 0) or '0.00'"/>
                                    </div>
                                </div>
                            </div>

                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Remarks</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-yend">Rate</th>
                                        <th class="text-yend">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.direct_deposit_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="line.product_id.name"/></td>
                                            <td><t t-esc="line.remarks or '-'"/></td>
                                            <td class="text-end"><t t-esc="line.quantity"/></td>
                                            <!-- <td class="text-end"><t t-esc="line.product_id.list_price"/></td> -->
                                            <td class="text-end"><t t-esc="'{:,}'.format(int(line.amount) or 0) or '-'"/></td>
                                            <td class="text-end"><t t-esc="'{:,}'.format(int(line.quantity*line.amount or 0)) or '-'"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <hr style="margin:4px 0"/>

                            <!-- ===== TOTALS ===== -->
                            <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px;">
                                <div>Entered by: <strong><t t-esc="o.user_id.name"/></strong></div>
                                <div>Total Amount: <strong>Rs <t t-esc="'{:,}'.format(int(o.amount) or 0)"/></strong></div>
                            </div>

                            <hr style="margin:4px 0; border-top: solid 5px;"/>

                            <div class="row mb-2">
                                <div style="display: flex; margin-bottom: 5px; font-size: 12px;">
                                    
                                </div>

                                <div class="col-6">
                                    <div><strong>DD #:</strong> <t t-esc="o.name or '--'"/></div>
                                    <div><strong>Donor Name:</strong> <t t-esc="o.donor_id.name or '-'"/></div>
                                    <div>
                                        <t t-set="count" t-value="1"/>
                                        <strong>Products:</strong>
                                        <t t-foreach="o.direct_deposit_line_ids" t-as="l">
                                            <div><t t-esc="count"/>. <t t-esc="l.product_id.name"/> - <t t-esc="int(l.quantity)"/></div>
                                            <t t-set="count" t-value="count + 1"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date &amp; Time:</strong>
                                        <t t-esc="o.create_date.strftime('%d-%m-%Y %H:%M') if o.create_date else '--'"/>
                                    </div>
                                    <div><strong>Entered by: </strong> <t t-esc="o.user_id.name"/></div>
                                </div>
                            </div>

                            <div style="text-align: center; font-size: 12px;">
                                Powered by BytesNode
                            </div>

                        </div>

                    </t>
                </t>
            </t>
        </template>

        <record id="report_direct_deposit_duplicate_paperformat" model="report.paperformat">
            <field name="name">A5 - Direct Deposit Duplicate Receipt</field>
            <field name="format">A5</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">0</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">4</field>
            <field name="margin_right">4</field>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="report_direct_deposit_duplicate" model="ir.actions.report">
            <field name="name">Direct Deposit Receipt Duplicate</field>
            <field name="model">direct.deposit</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bn_direct_deposit.direct_deposit_receipt_template_duplicate</field>
            <field name="report_file">bn_direct_deposit.direct_deposit_receipt_template_duplicate</field>
            <field name="binding_model_id" ref="bn_direct_deposit.model_direct_deposit"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Deposit Receipt - %s' % (object.name)</field>
            <field name="id" ref="bn_direct_deposit.report_direct_deposit_duplicate_paperformat"/>
        </record>

    </data>
</odoo>