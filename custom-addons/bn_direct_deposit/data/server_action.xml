<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="direct_deposit_action_server" model="ir.actions.server">
            <field name="name">Update Direct Deposit Total Amount | BN</field>
            <field name="model_id" ref="model_direct_deposit"/>
            <field name="binding_model_id" ref="model_direct_deposit"/>
            <field name="state">code</field>
            <field name="code">
                for record in records:
                    record.calculate_amount()
            </field>
        </record>
        
        <record id="direct_deposit_remarks_action_server" model="ir.actions.server">
            <field name="name">Update Direct Deposit Remarks | BN</field>
            <field name="model_id" ref="model_direct_deposit"/>
            <field name="binding_model_id" ref="model_direct_deposit"/>
            <field name="state">code</field>
            <field name="code">
                for record in records:
                    record.set_remarks()
            </field>
        </record>
    
    </data>
    

</odoo>
