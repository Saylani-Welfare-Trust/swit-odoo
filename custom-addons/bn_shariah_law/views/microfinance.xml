<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="microfinance_view_form_inherit_bn_shariah_law" model="ir.ui.view">
        <field name="name">microfinance.view.form.inherit.bn.shariah.law</field>
        <field name="model">microfinance</field>
        <field name="inherit_id" ref="bn_microfinance.microfinance_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="after">
                <field name="is_sync_shariah_law" readonly="1" />
            </xpath>
        </field>
    </record>

</odoo>
