<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="shariah_law_view_tree" model="ir.ui.view">
        <field name="name">shariah.law.view.tree</field>
        <field name="model">shariah.law</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="parent_id" column_invisible="1" string="Segment" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
                <field name="analytic_account_id" string="Segment" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
                
                <!-- Opening/Closing Balances -->
                <field name="opening_balance" sum="Total" />
                <field name="closing_balance" sum="Total" />
                
                <!-- Donation Sources -->
                <field name="pos_donation_amount" sum="Total" />
                <field name="api_donation_amount" sum="Total" />
                <field name="dik_amount" sum="Total" />
                <field name="po_amount" sum="Total" />
                <field name="welfare_amount" sum="Total" />
                <field name="microfinance_amount" sum="Total" />
                <field name="total_donation" sum="Total" />
                
                <!-- Expenses and Transfers -->
                <field name="expense_amount" sum="Total" />
                <field name="transfer_in_amount" sum="Total" />
                <field name="transfer_out_amount" sum="Total" />
                <field name="net_transfer" sum="Total" />

                <button string="Transfer" name="action_transfer" type="object" class="btn-primary"/>
            </tree>
        </field>
    </record>

    <record id="shariah_law_view_form" model="ir.ui.view">
        <field name="name">shariah.law.view.form</field>
        <field name="model">shariah.law</field>
        <field name="arch" type="xml">
            <form string="Shariah Law">
                <sheet>
                    <group>
                        <group>
                            <field name="analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="parent_id" readonly="1"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    
                    <group string="Daily Balances (Today)">
                        <group>
                            <field name="opening_balance" readonly="1"/>
                            <field name="closing_balance" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="Donations by Source" colspan="2">
                        <group>
                            <field name="pos_donation_amount" readonly="1"/>
                            <field name="api_donation_amount" readonly="1"/>
                            <field name="dik_amount" readonly="1"/>
                            <field name="po_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="welfare_amount" readonly="1"/>
                            <field name="microfinance_amount" readonly="1"/>
                            <field name="total_donation" readonly="1" style="font-weight: bold;"/>
                        </group>
                    </group>
                    
                    <group string="Expenses &amp; Transfers" colspan="2">
                        <group>
                            <field name="expense_amount" readonly="1"/>
                            <field name="transfer_in_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="transfer_out_amount" readonly="1"/>
                            <field name="net_transfer" readonly="1" style="font-weight: bold;"/>
                        </group>
                    </group>
                    
                    <group>
                        <button name="action_transfer" type="object" string="Transfer" class="btn-primary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="shariah_law_action" model="ir.actions.act_window">
        <field name="name">Shariah Law Totals</field>
        <field name="res_model">shariah.law</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Shariah-compliant tracking of donations, purchases, expenses, and transfers.
            </p>
        </field>
    </record>

</odoo>