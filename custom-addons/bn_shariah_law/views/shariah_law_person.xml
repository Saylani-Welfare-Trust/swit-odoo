<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View Only -->
    <record id="view_shariah_law_person_tree" model="ir.ui.view">
        <field name="name">shariah.law.person.view.tree</field>
        <field name="model">shariah.law.person</field>
        <field name="arch" type="xml">
            <tree string="Shariah Law Persons" editable="bottom" delete="0">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="shariah_law_person_action" model="ir.actions.act_window">
        <field name="name">Shariah Law Persons</field>
        <field name="res_model">shariah.law.person</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage Shariah Law Persons responsible for fund transfers.
                <br/><br/>
                <b>Note:</b> These persons will be assigned to transfers for approval and tracking purposes.
            </p>
        </field>
    </record>

</odoo>