<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="analytic_view_account_analytic_account_form_inherit_bn_shariah_law" model="ir.ui.view">
        <field name="name">analytic.view.account.analytic.account.form.inherit.bn.shariah.law</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='address']" position="after">
                <field name="member_approval"/>
                <field name="product_ids" widget="many2many_tags" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
            </xpath>
        </field>
    </record>

</odoo>
