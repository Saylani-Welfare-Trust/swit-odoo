<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View Only -->
    <record id="view_shariah_law_blocker_tree" model="ir.ui.view">
        <field name="name">shariah.law.blocker.view.tree</field>
        <field name="model">shariah.law.blocker</field>
        <field name="arch" type="xml">
            <tree string="Shariah Law Blocker" editable="bottom" create="0" delete="0">
                <field name="company_id"/>
                <field name="enable_pos" widget="boolean_toggle"/>
                <field name="enable_donations" widget="boolean_toggle"/>
                <field name="enable_dik" widget="boolean_toggle"/>
                <field name="enable_api_donation" widget="boolean_toggle"/>
                <field name="enable_expense" widget="boolean_toggle"/>
                <field name="enable_purchase" widget="boolean_toggle"/>
                <field name="enable_welfare" widget="boolean_toggle"/>
                <field name="enable_microfinance" widget="boolean_toggle"/>
                <field name="enable_transfer" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="shariah_law_blocker_action" model="ir.actions.act_window">
        <field name="name">Shariah Law Blocker</field>
        <field name="res_model">shariah.law.blocker</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Enable/Disable modules for Shariah Law syncing.
                <br/><br/>
                <b>Note:</b> Uncheck a module to block its sync with Shariah Law.
            </p>
        </field>
    </record>

</odoo>