<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shariah_transfer_tree" model="ir.ui.view">
        <field name="name">shariah.transfer.tree</field>
        <field name="model">shariah.transfer</field>
        <field name="arch" type="xml">
            <tree string="Transfers">
                <field name="name"/>
                <field name="date"/>
                <field name="source_analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                <field name="destination_analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                <field name="amount" sum="Total"/>
                <field name="state" widget="badge"/>
                <field name="member_posted"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_shariah_transfer_form" model="ir.ui.view">
        <field name="name">shariah.transfer.form</field>
        <field name="model">shariah.transfer</field>
        <field name="arch" type="xml">
            <form string="Transfer">
                <header>
                    <button name="action_member_post" string="Member Post" type="object" class="btn-primary" groups="bn_shariah_law.group_member_approval" invisible="state != 'draft'"/>
                    <button name="action_post" string="Post" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date"/>
                            <field name="source_analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="destination_analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="member_posted" readonly="state == 'posted'"/>
                        </group>
                    </group>
                    <field name="note" nolabel="1" placeholder="Optional note"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_shariah_transfer" model="ir.actions.act_window">
        <field name="name">Transfers</field>
        <field name="res_model">shariah.transfer</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_state': 'draft'}</field>
    </record>

</odoo>