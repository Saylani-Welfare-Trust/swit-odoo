<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_shariah_daily_balance_tree" model="ir.ui.view">
        <field name="name">shariah.daily.balance.tree</field>
        <field name="model">shariah.daily.balance</field>
        <field name="arch" type="xml">
            <tree string="Daily Balances" create="0" edit="0" delete="0">
                <field name="date"/>
                <field name="analytic_account_id" domain="[('plan_id.name', '=', 'Segment')]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                
                <!-- Opening Balances -->
                <field name="opening_balance" sum="Total" widget="monetary"/>
                
                <!-- POSITIVE Transactions (Increase Balance) -->
                <field name="pos_donation" sum="Total" widget="monetary"/>
                <field name="api_donation" sum="Total" widget="monetary"/>
                <field name="dik" sum="Total" widget="monetary"/>
                
                <!-- NEGATIVE Transactions (Decrease Balance) -->
                <field name="po" sum="Total" widget="monetary"/>
                <field name="welfare" sum="Total" widget="monetary"/>
                <field name="microfinance" sum="Total" widget="monetary"/>
                <field name="expense" sum="Total" widget="monetary"/>
                
                <!-- Total Donation (POSITIVE only) -->
                <field name="total_donation" sum="Total" widget="monetary"/>
                
                <!-- Transfer (Unified - Positive for IN, Negative for OUT) -->
                <field name="transfer" sum="Total" widget="monetary"/>
                
                <!-- Closing Balances -->
                <field name="closing_balance" sum="Total" widget="monetary"/>
            </tree>
        </field>
    </record>

    <record id="view_shariah_daily_balance_search" model="ir.ui.view">
        <field name="name">shariah.daily.balance.search</field>
        <field name="model">shariah.daily.balance</field>
        <field name="arch" type="xml">
            <search>
                <field name="analytic_account_id" string="Segment"/>
                <filter name="today" string="Today" domain="[('date', '=', context_today())]"/>
                <filter name="this_week" string="This Week" domain="[('date', '>=', context_today().strftime('%Y-%m-%d')), ('date', '&gt;=', (context_today() + timedelta(days=6)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="This Month" domain="[('date', '>=', context_today().replace(day=1).strftime('%Y-%m-%d')), ('date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="last_month" string="Last Month" domain="[('date', '>=', (context_today().replace(day=1) - timedelta(days=1)).replace(day=1).strftime('%Y-%m-%d')), ('date', '&gt;=', (context_today().replace(day=1) - timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="positive_balance" string="Positive Balance" domain="[('closing_balance', '>', 0)]"/>
                <filter name="negative_balance" string="Negative Balance" domain="[('closing_balance', '<', 0)]"/>
                <filter name="zero_balance" string="Zero Balance" domain="[('closing_balance', '=', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_date" string="Date" domain="[]" context="{'group_by': 'date'}"/>
                    <filter name="group_by_analytic" string="Segment" domain="[]" context="{'group_by': 'analytic_account_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shariah_daily_balance" model="ir.actions.act_window">
        <field name="name">Daily Balances</field>
        <field name="res_model">shariah.daily.balance</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_shariah_daily_balance_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Track daily balances for each Shariah-compliant segment.
            </p>
            <p>
                <strong>Transaction Signs:</strong><br/>
                + POS Donation, API Donation, DIK, Transfer IN<br/>
                - PO, Welfare, Microfinance, Expense, Transfer OUT
            </p>
            <p>
                <strong>Balance Calculation:</strong><br/>
                Closing = Opening + Total Donation + Transfer - PO - Welfare - Microfinance - Expense
            </p>
            <p>
                <strong>Note:</strong> PO, Welfare, Microfinance, and Expense are stored as negative values in the system.
            </p>
        </field>
    </record>

    <!-- Add menu item if needed -->
    <menuitem 
        id="shariah_daily_balance_menu" 
        name="Daily Balances" 
        parent="shariah_law_menu" 
        action="action_shariah_daily_balance"
        sequence="20"/>

</odoo>