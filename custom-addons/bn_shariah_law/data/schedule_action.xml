<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Cron Job for POS Orders Sync -->
    <record id="cron_sync_pos_orders" model="ir.cron">
        <field name="name">Sync POS Orders - Shariah Law</field>
        <field name="model_id" ref="model_shariah_law"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="state">code</field>
        <field name="code">model._sync_pos_orders()</field>
    </record>

