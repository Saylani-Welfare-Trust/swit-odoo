<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Welfare Line Wizard Form View -->
    <record id="view_welfare_line_wizard_form" model="ir.ui.view">
        <field name="name">welfare.line.wizard.form</field>
        <field name="model">welfare.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Welfare Line Details">
                <sheet>
                    <div class="oe_title">
                        <h1>Welfare Disbursement Details</h1>
                    </div>
                    
                    <div class="o_form_sheet_bg" style="max-height: 70vh; overflow-y: auto;">
                        
                        <!-- Applicant Information -->
                        <separator string="Applicant Information" class="text-uppercase"/>
                        <group>
                            <group>
                                <field name="applicant_name"/>
                                <field name="cnic_no"/>
                                <field name="father_name"/>
                            </group>
                            <group>
                                <field name="phone"/>
                                <field name="address"/>
                            </group>
                        </group>
                        
                        <!-- Disbursement Details -->
                        <separator string="Disbursement Details" class="text-uppercase"/>
                        <group>
                            <group>
                                <field name="disbursement_category_id"/>
                                <field name="product_id"/>
                                <field name="collection_point"/>
                            </group>
                            <group>
                                <field name="collection_date"/>
                                <field name="quantity"/>
                                <field name="total_amount" widget="monetary"/>
                            </group>
                        </group>
                        
                        <!-- Status Section -->
                        <separator string="Status" class="text-uppercase"/>
                        <group>
                            <group>
                                <field name="state" 
                                       widget="selection" 
                                       options="{'always_reload': True}"
                                       decoration-warning="state == 'draft'" 
                                       decoration-success="state == 'collected'"
                                       decoration-info="state in ['submitted', 'approved']"
                                       decoration-danger="state == 'rejected'"/>
                            </group>
                        </group>
                        
                    </div>
                </sheet>
                
                <footer>
                    <button name="action_mark_as_collected" 
                            string="Mark as Collected" 
                            type="object" 
                            class="btn-primary"
                            attrs="{'invisible': [('state', '=', 'collected')]}"/>
                    <button string="Close" special="cancel" class="btn-default"/>
                </footer>
            </form>
        </field>
    </record>
    
    <!-- Action to open the wizard -->
    <record id="action_welfare_line_wizard" model="ir.actions.act_window">
        <field name="name">View Welfare Line Details</field>
        <field name="res_model">welfare.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_welfare_line_wizard_form"/>
    </record>
    
</odoo>