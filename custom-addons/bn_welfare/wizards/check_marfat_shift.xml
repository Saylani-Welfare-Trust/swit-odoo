<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Check Marfat Shift Wizard Form View -->
    <record id="check_marfat_shift_form" model="ir.ui.view">
        <field name="name">check.marfat.shift.form</field>
        <field name="model">check.marfat.shift</field>
        <field name="arch" type="xml">
            <form string="Check Assigned Officer (Marfat) Shift">
                <header>
                    <button name="action_check_shift" string="Check Shift" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h2>Check Assigned Officer Disbursements</h2>
                    </div>
                    
                    <group name="officer_info">
                        <group>
                            <field name="employee_category_id_officer" invisible="1" />
                            <field name="assigned_officer_id" required="1" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="officer_name" string="Officer Name"/>
                            <field name="officer_address" string="Address"/>
                        </group>
                    </group>

                    <separator string="Disbursement Lines" class="text-uppercase"/>
                    
                    <!-- Scrollable tree with only state field editable and donee details -->
                    <field name="disbursement_line_ids" nolabel="1">
                        <tree editable="bottom" create="false" delete="false" style="max-height: 400px; overflow-y: auto;">
                            <!-- Donee Information -->
                            <field name="donee_name" string="Donee Name" readonly="1"/>
                            <field name="donee_address" string="Donee Address" readonly="1"/>
                            <field name="donee_mobile" string="Mobile" readonly="1"/>
                            <field name="donee_cnic" string="CNIC" readonly="1"/>
                            
                            <!-- Disbursement Information -->
                            <field name="welfare_id" string="Welfare Record" readonly="1"/>
                            <field name="disbursement_category_id" string="Disbursement Category" readonly="1"/>
                            <field name="product_id" string="Product" readonly="1"/>
                            <field name="collection_point" string="Collection Point" readonly="1"/>
                            <field name="collection_date" string="Collection Date" readonly="1"/>
                            <field name="quantity" string="Quantity" readonly="1"/>
                            <field name="total_amount" string="Total Amount" readonly="1"/>
                            
                            <!-- Editable State Field -->
                            <field name="state" 
                                   widget="selection" 
                                   options="{'always_reload': True}"
                                   readonly="0"
                                   required="1"
                                   decoration-warning="state == 'draft'" 
                                   decoration-success="state == 'collected'"
                                   decoration-info="state in ['submitted', 'approved']"
                                   decoration-danger="state == 'rejected'"/>
                        </tree>
                    </field>
                    
                    <footer>
                        <button name="action_mark_as_collected" string="Mark all as Collected" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Check Marfat Shift -->
    <record id="action_check_marfat_shift" model="ir.actions.act_window">
        <field name="name">Check Assigned Officer Shift</field>
        <field name="res_model">check.marfat.shift</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="check_marfat_shift_form"/>
    </record>

    <!-- Menu Item for Check Marfat Shift -->
    <menuitem
        id="menu_check_marfat_shift"
        name="Check Assigned Officer Shift"
        action="action_check_marfat_shift"
        parent="welfare_menu"
        groups="bn_welfare.welfare_group"
        sequence="25"/>

</odoo>