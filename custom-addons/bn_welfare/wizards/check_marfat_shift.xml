<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Check Marfat Shift Wizard Form View -->
    <record id="check_marfat_shift_form" model="ir.ui.view">
        <field name="name">check.marfat.shift.form</field>
        <field name="model">check.marfat.shift</field>
        <field name="arch" type="xml">
            <form string="Check Assigned Officer (Marfat) Shift">
                <header>
                    <button name="action_check_shift" string="Check Shift" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h2>Check Assigned Officer Disbursements</h2>
                    </div>
                    
                    <group>
                        <group>
                            <field name="employee_category_id_officer" invisible="1" />
                            <field name="assigned_officer_id" required="1" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Disbursement Lines" class="text-uppercase"/>
                    
                    <!-- Put page inside notebook -->
                    <notebook>
                        <page string="Disbursement Lines">
                            <field name="disbursement_line_ids" readonly="1" nolabel="1" mode="tree">
                                <tree>
                                    <field name="welfare_id" string="Welfare Record"/>
                                    <field name="disbursement_category_id" string="Disbursement Category"/>
                                    <field name="product_id" string="Product"/>
                                    <field name="collection_point" string="Collection Point"/>
                                    <field name="collection_date" string="Collection Date"/>
                                    <field name="quantity" string="Quantity"/>
                                    <field name="total_amount" string="Total Amount"/>
                                    <button name="open_disbursement_popup" string="Details" type="object" class="btn-secondary"/>
                                    <!-- <button name="mark_selected_as_collected" string="Mark Selected as Collected" type="object" class="btn-primary"/> -->
                                    <field name="state" 
                                            widget="selection" 
                                            options="{'always_reload': True}"
                                            decoration-warning="state == 'draft'" 
                                            decoration-success="state == 'collected'"
                                            decoration-info="state in ['submitted', 'approved']"
                                            decoration-danger="state == 'rejected'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Recurring Lines">
                            <field name="recurring_line_ids" readonly="1" nolabel="1" mode="tree">
                                <tree>
                                    <field name="welfare_id" string="Welfare Record"/>
                                    <field name="disbursement_category_id" string="Disbursement Category"/>
                                    <field name="product_id" string="Product"/>
                                    <field name="collection_point" string="Collection Point"/>
                                    <field name="collection_date" string="Collection Date"/>
                                    <field name="quantity" string="Quantity"/>
                                    <field name="amount" string="Amount"/>
                                    <button name="open_recurring_disbursement_popup" string="Details" type="object" class="btn-secondary"/>
                                    <field name="state"
                                            widget="selection"
                                            options="{'always_reload': True}"
                                            decoration-warning="state == 'draft'"
                                            decoration-success="state == 'collected'"
                                            decoration-info="state in ['submitted', 'approved']"
                                            decoration-danger="state == 'rejected'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
  
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_welfare_line_disbursement_popup_form" model="ir.ui.view">
        <field name="name">welfare.line.disbursement.popup.form</field>
        <field name="model">welfare.line.disbursement.popup</field>
        <field name="arch" type="xml">
            <form string="Disbursement Details" create="false" edit="false">
                <sheet>
                    <group string="Donee Information">
                        <field name="line_id" invisible="1"/>
                        <field name="donee_id" readonly="1"/>
                        <field name="donee_cnic_no" readonly="1"/>
                        <field name="donee_mobile" readonly="1"/>
                        <field name="donee_street" readonly="1"/>
                        <field name="donee_street2" readonly="1"/>
                        <field name="donee_city" readonly="1"/>
                        <field name="donee_state_id" readonly="1"/>
                        <field name="donee_country_id" readonly="1"/>
                    </group>
                    <group string="Disbursement Information">
                        <field name="disbursement_category_id" readonly="1"/>
                        <field name="disbursement_application_type_id" readonly="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="quantity" readonly="1"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="collection_point" readonly="1"/>
                        <field name="collection_date" readonly="1"/>
                        <field name="assigned_officer_id" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_disbursed" type="object" string="Mark as Done" class="btn-primary"/>
                    <button name="action_mark_pending" type="object" string="Mark as Pending" class="btn-secondary"/>
                    <button string="Close" class="btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_welfare_recurring_line_disbursement_popup_form" model="ir.ui.view">
        <field name="name">welfare.recurring.line.disbursement.popup.form</field>
        <field name="model">welfare.recurring.line.disbursement.popup</field>
        <field name="arch" type="xml">
            <form string="Recurring Disbursement Details" create="false" edit="false">
                <sheet>
                    <group string="Donee Information">
                        <field name="recurring_line_id" invisible="1"/>
                        <field name="donee_id" readonly="1"/>
                        <field name="donee_cnic_no" readonly="1"/>
                        <field name="donee_mobile" readonly="1"/>
                        <field name="donee_street" readonly="1"/>
                        <field name="donee_street2" readonly="1"/>
                        <field name="donee_city" readonly="1"/>
                        <field name="donee_state_id" readonly="1"/>
                        <field name="donee_country_id" readonly="1"/>
                    </group>
                    <group string="Recurring Disbursement Information">
                        <field name="disbursement_category_id" readonly="1"/>
                        <field name="disbursement_application_type_id" readonly="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="quantity" readonly="1"/>
                        <field name="amount" readonly="1"/>
                        <field name="collection_point" readonly="1"/>
                        <field name="collection_date" readonly="1"/>
                        <field name="assigned_officer_id" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_disbursed" type="object" string="Mark as Done" class="btn-primary"/>
                    <button string="Close" class="btn-link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for Check Marfat Shift -->
    <record id="action_check_marfat_shift" model="ir.actions.act_window">
        <field name="name">Check Assigned Officer Shift</field>
        <field name="res_model">check.marfat.shift</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item for Check Marfat Shift -->
    <menuitem
        id="menu_check_marfat_shift"
        name="Check Assigned Officer Shift"
        action="action_check_marfat_shift"
        parent="welfare_menu"
        groups="bn_welfare.welfare_group"
        sequence="25"/>

</odoo>
