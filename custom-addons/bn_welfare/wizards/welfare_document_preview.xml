<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="welfare_document_preview_form" model="ir.ui.view">
        <field name="name">welfare.document.preview.form</field>
        <field name="model">welfare.document.preview</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="document_id" string="Document Name"/></h1>
                    </div>
                    <group>
                        <field name="image_data" widget="image" class="oe_avatar" 
                            options="{'zoom': true}" nolabel="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Close" name="action_close" type="object" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="welfare_document_preview_action" model="ir.actions.act_window">
        <field name="name">Document Preview</field>
        <field name="res_model">welfare.document.preview</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_welfare_document"/>
    </record>
</odoo>