<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_welfare_document_preview_form" model="ir.ui.view">
        <field name="name">welfare.document.preview.form</field>
        <field name="model">welfare.document.preview</field>
        <field name="arch" type="xml">
            <form>
                <div class="modal-dialog modal-lg" style="width: 800px;">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h4 class="modal-title">Document Preview: <field name="name"/></h4>
                        </div>
                        <div class="modal-body">
                            <group>
                                <field name="image_data" widget="image" 
                                    options="{'zoomable': true, 'size': [600, 600]}"
                                    class="img-responsive center-block"/>
                            </group>
                        </div>
                        <div class="modal-footer">
                            <button name="action_download" type="object" 
                                    string="Download" class="btn-primary"/>
                            <button name="action_close" type="object" 
                                    string="Close" class="btn-secondary" special="cancel"/>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>
</odoo>