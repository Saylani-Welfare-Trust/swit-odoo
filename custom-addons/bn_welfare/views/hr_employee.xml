<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_employee_form_view_inherit_bn_welfare" model="ir.ui.view">
        <field name="name">hr.employee.form.view.inherit.bn.welfare</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_email']" position="after">
                    <field name="area" options="{'no_create': True, 'no_edit': True}" widget="many2many_tags" />
            </xpath>
        </field>
    </record>

</odoo>
