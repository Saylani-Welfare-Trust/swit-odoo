<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_welfare_consolidated_tree" model="ir.ui.view">
        <field name="name">welfare.line.tree</field>
        <field name="model">welfare.line</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="product_domain" column_invisible="1" />
                <field name="analytic_account_domain" column_invisible="1" />
                <field name="is_collection_point_readonly" column_invisible="1" />
                <field name="employee_category_id_officer" column_invisible="1" />

                <field name="recurring_duration" column_invisible="order_type != 'recurring'" />
                <field name="disbursement_category_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
                <field name="disbursement_application_type_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
                <field name="product_id" domain="product_domain" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />
                <field name="payment_type" />
                <field name="assigned_officer_id" domain="[('category_ids', 'in', [employee_category_id_officer])]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="payment_type == 'self'" />
                <field name="collection_point" readonly="is_collection_point_readonly"/>
                <field name="analytic_account_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" domain="analytic_account_domain" invisible="collection_point == 'bank'" />
                <field name="collection_date" />
                <field name="marriage_date" invisible="disbursement_category_id.name != 'Marriage / Wedding'" />
                <field name="quantity" />
                <field name="amount" readonly="1" />
                <field name="fixed_amount_check" column_invisible="1" />
                <field name="total_amount" readonly="fixed_amount_check" />
                <field name="advance_donation_amount" optional="hide" string="Advance Donation Amount" readonly="1"/>

                <field name="show_deliver_button" column_invisible="1"/>
                <button name="action_return_to_draft" string="Return to Draft" type="object" class="btn-secondary" invisible="state != 'return'" />
                <button name="action_delivered" type="object" string="Create Delivery" class="oe_highlight" column_invisible="1"/>
                <field name="state" widget="badge" decoration-warning="state == 'draft'" decoration-success="state == 'disbursed'" string="State" />
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_welfare_consolidated_search" model="ir.ui.view">
        <field name="name">welfare.line.search</field>
        <field name="model">welfare.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="disbursement_category_id"/>
                <field name="state"/>

                <filter name="regular" string="Regular" domain="[('order_type','!=','recurring')]"/>
                <filter name="recurring" string="Recurring" domain="[('order_type','=','recurring')]"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="disbursed" string="Disbursed" domain="[('state','=','disbursed')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_category" string="Category" context="{'group_by':'disbursement_category_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by':'order_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_welfare_consolidated" model="ir.actions.act_window">
        <field name="name">All Welfare Lines</field>
        <field name="res_model">welfare.line</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_welfare_consolidated_search"/>
        <field name="target">current</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_welfare_consolidated"
        name="All Welfare Lines"
        action="action_welfare_consolidated"
        parent="welfare_menu"
        groups="bn_welfare.welfare_group"
        sequence="50"/>

</odoo>