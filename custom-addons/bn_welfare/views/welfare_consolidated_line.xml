<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_welfare_consolidated_tree" model="ir.ui.view">
        <field name="name">welfare.consolidated.line.tree</field>
        <field name="model">welfare.consolidated.line</field>
        <field name="arch" type="xml">
            <tree string="All Welfare Lines" default_order="collection_date desc">
                <field name="is_recurring" string="Type" widget="badge" 
                       decoration-info="is_recurring == True"
                       decoration-success="is_recurring == False"/>
                <field name="employee_id" string="Employee"/>
                <field name="disbursement_category_id" string="Category"/>
                <field name="product_id" string="Product"/>
                <field name="collection_date"/>
                <field name="quantity" sum="Total"/>
                <field name="total_amount" sum="Total"/>
                <field name="state" widget="badge"/>
                <button name="action_open_source_record" 
                        string="Open" 
                        type="object" 
                        class="btn-secondary"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_welfare_consolidated_form" model="ir.ui.view">
        <field name="name">welfare.consolidated.line.form</field>
        <field name="model">welfare.consolidated.line</field>
        <field name="arch" type="xml">
            <form string="Welfare Line">
                <header>
                    <button name="action_open_source_record" 
                            string="Open Source" 
                            type="object" 
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="disbursement_category_id"/>
                            <field name="product_id"/>
                            <field name="collection_date"/>
                        </group>
                        <group>
                            <field name="is_recurring"/>
                            <field name="recurring_duration" invisible="not is_recurring"/>
                            <field name="quantity"/>
                            <field name="total_amount"/>
                            <field name="state" widget="badge"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_welfare_consolidated_search" model="ir.ui.view">
        <field name="name">welfare.consolidated.line.search</field>
        <field name="model">welfare.consolidated.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="disbursement_category_id"/>
                <field name="state"/>
                
                <filter name="regular" string="Regular" domain="[('is_recurring','=',False)]"/>
                <filter name="recurring" string="Recurring" domain="[('is_recurring','=',True)]"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="disbursed" string="Disbursed" domain="[('state','=','disbursed')]"/>
                
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_category" string="Category" context="{'group_by':'disbursement_category_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by':'is_recurring'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_welfare_consolidated" model="ir.actions.act_window">
        <field name="name">All Welfare Lines</field>
        <field name="res_model">welfare.consolidated.line</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_welfare_consolidated_search"/>
        <field name="target">current</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_welfare_consolidated"
        name="All Welfare Lines"
        action="action_welfare_consolidated"
        parent="welfare_menu"
        groups="bn_welfare.welfare_group"
        sequence="50"/>

</odoo>