<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_welfare_return_line_tree" model="ir.ui.view">
        <field name="name">welfare.return.line.tree</field>
        <field name="model">welfare.return.line</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="welfare_id"/>
                <field name="welfare_line_id"/>
                <field name="donee_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="total_amount"/>
                <field name="return_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

</odoo>
