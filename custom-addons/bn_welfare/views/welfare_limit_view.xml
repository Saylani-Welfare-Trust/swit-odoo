<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_welfare_approval_limit_tree" model="ir.ui.view">
        <field name="name">welfare.approval.limit.tree</field>
        <field name="model">welfare.approval.limit</field>
        <field name="arch" type="xml">
            <tree string="Approval Limits">
                <field name="group_id"/>
                <field name="group_name"/>
                <field name="max_amount_limit" widget="monetary"/>
                <field name="allowed_product_master_ids" widget="many2many_tags"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_welfare_approval_limit_form" model="ir.ui.view">
        <field name="name">welfare.approval.limit.form</field>
        <field name="model">welfare.approval.limit</field>
        <field name="arch" type="xml">
            <form string="Approval Limit Configuration">
                <sheet>
                    <group>
                        <group>
                            <field name="group_id" required="1"/>
                            <field name="max_amount_limit" widget="monetary" required="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="allowed_product_master_ids" 
                                   widget="many2many_tags"
                                   placeholder="Leave empty to allow all products"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_welfare_approval_limit" model="ir.actions.act_window">
        <field name="name">Approval Limits</field>
        <field name="res_model">welfare.approval.limit</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure approval limits for HOD group
            </p>
            <p>
                Set maximum amount and allowed products for HOD approval.
                If limit is crossed, request will automatically go to Member Approval.
            </p>
        </field>
    </record>

    <!-- Menu under Master Setup -->
    <menuitem id="menu_welfare_master_setup" 
              name="Welfare Master" 
              parent="base.menu_base_config"
              sequence="100"/>
    
    <menuitem id="menu_welfare_approval_limits" 
              name="Approval Limits" 
              parent="menu_welfare_master_setup"
              action="action_welfare_approval_limit"
              sequence="10"/>
</odoo>