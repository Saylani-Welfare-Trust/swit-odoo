<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_advance_donation_wizard" model="ir.ui.view">
        <field name="name">advance.donation.wizard.form</field>
        <field name="model">advance.donation.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Advance Donation">
                <group>
                    <field name="advance_donation_id" options="{'no_create': True}"/>
                    <field name="product_id" options="{'no_create': True}"/>
                    <!-- Hidden context fields -->
                    <field name="welfare_line_id" invisible="1"/>
                    <field name="recurring_line_id" invisible="1"/>
                    <field name="microfinance_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_show_lines" string="Next" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_advance_donation_line_selection_wizard" model="ir.ui.view">
        <field name="name">advance.donation.line.selection.wizard.form</field>
        <field name="model">advance.donation.line.selection.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Donation Line">
                <group>
                    <field name="advance_donation_id" readonly="1"/>
                    <field name="product_id" readonly="1"/>
                </group>
                <field name="donation_line_ids">
                    <tree editable="bottom">
                        <field name="product_id" readonly="1"/>
                        <field name="paid_amount" readonly="1"/>
                        <field name="is_reserved" readonly="1"/>
                        <field name="is_selected"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_advance_donation_wizard" model="ir.actions.act_window">
        <field name="name">Select Advance Donation Line</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">advance.donation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <!-- <field name="binding_model_id" ref="bn_advance_donation_syncing.model_welfare_line" />  Replace module_name with your module's name -->
    </record>
</odoo>