<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_counterfeit_notes_wizard_form" model="ir.ui.view">
        <field name="name">counterfeit.notes.wizard.form</field>
        <field name="model">counterfeit.notes.wizard</field>
        <field name="arch" type="xml">
            <form string="Create CFB">
                <group>
                    <field name="total_amount" readonly="1"/>
                    <field name="actual_amount"/>
                    <field name="lot_id" readonly="1"/>
                </group>
                <footer>
                    <button name="action_submit_cfb" type="object" string="Save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
