<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_foreign_currency_wizard_form" model="ir.ui.view">
    <field name="name">foreign.currency.wizard.form</field>
    <field name="model">foreign.currency.wizard</field>
    <field name="arch" type="xml">
        <form string="Create Foreign Currency Lines">
            <group>
                <field name="line_count"/>
                <!-- <button name="action_generate_lines" type="object"
                        string="Generate Lines" class="btn-secondary"/> -->
            </group>

            <field name="line_ids">
                <tree editable="bottom">
                    <field name="amount"/>
                </tree>
            </field>

            <footer>
                <button name="action_create_lines" type="object"
                        string="Create" class="btn-primary"/>
                <button string="Cancel" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

</odoo>
