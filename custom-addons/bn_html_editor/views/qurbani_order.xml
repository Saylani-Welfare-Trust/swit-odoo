<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_order_view_form_inherit_bn_html_editor" model="ir.ui.view">
        <field name="name">qurbani.order.view.form.inherit.bn.html.editor</field>
        <field name="model">qurbani.order</field>
        <field name="inherit_id" ref="bn_qurbani.qurbani_order_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='remarks']" position="after">
                <field name="description" widget="word_editor"/>
            </xpath>
        </field>
    </record>

</odoo>
