<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ration_packing_action" model="ir.actions.act_window">
        <field name="name">Ration Packing</field>
        <field name="res_model">mrp.bom</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ration packing found. Let's create one!

                Ration Packing allow you to define the list of required raw materials used to make a finished product; through a manufacturing order or a pack of products.
            </p>
        </field>
    </record>

    <menuitem
        id="kitchen_menu"
        name="Kitchen"
        web_icon="bn_kitchen,static/description/icon.png"
        sequence="6"/>

    <menuitem
        id="ration_packing_menu"
        name="Ration Packing"
        action="ration_packing_action"
        parent="bn_kitchen.kitchen_menu"
        sequence="0"/>

</odoo>
