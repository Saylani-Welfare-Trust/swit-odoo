<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_partner_form_whatsapp" model="ir.ui.view">
        <field name="name">res.partner.form.whatsapp</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='function']" position="before">
                <field name="whatsapp" placeholder="e.g., 03241234567" readonly="state == 'register'"/>
            </xpath>

        </field>  
    </record>

    <record id="bn_profile_management_form_whatsapp" model="ir.ui.view">
        <field name="name">bn.profile.management.form.whatsapp</field>
        <field name="model">res.partner</field> 
        <field name="inherit_id" ref="bn_profile_management.profile_management_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="whatsapp" placeholder="WhatsApp Number" readonly="state == 'register'"/>
            </xpath>

        </field>
    </record>
    
</odoo>