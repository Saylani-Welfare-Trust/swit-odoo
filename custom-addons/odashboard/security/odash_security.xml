<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_odashboard" model="ir.module.category">
        <field name="name">O'Dashboard</field>
        <field name="sequence">200</field>
    </record>

    <record id="group_odashboard_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_odashboard"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_odashboard_user'))]"/>
    </record>

</odoo>
