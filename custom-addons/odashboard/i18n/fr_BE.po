#. module: odashboard
#: model_terms:ir.ui.view,arch_db:odashboard.view_odashboard_api_key_form
msgid ""
"<i class=\"fa fa-lock me-2\" title=\"Lock\"/>\n"
"                        <strong>This is the default API key managed by O'Dashboard.</strong>\n"
"                        <br/>\n"
"                        This key is automatically created and renewed during synchronization.\n"
"                        It cannot be modified or viewed for security reasons."
msgstr ""
"<i class=\"fa fa-lock me-2\" title=\"Verrouillé\"/>\n"
"                        <strong>Ceci est la clé API par défaut gérée par O'Dashboard.</strong>\n"
"                        <br/>\n"
"                        Cette clé est automatiquement créée et renouvelée lors de la synchronisation.\n"
"                        Elle ne peut pas être modifiée ni consultée pour des raisons de sécurité."

#. module: odashboard
#: model_terms:ir.ui.view,arch_db:odashboard.view_odashboard_api_key_form
