<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bank_reconciliation_master_tree" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.tree</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <tree string="Bank Reconciliations">
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="state" widget="badge"/>
                <field name="total_transactions"/>
                <field name="reconciled_transactions"/>
                <field name="reconciliation_percentage" widget="progressbar"/>
                <field name="total_debit" sum="Total Debit" optional="hide"/>
                <field name="total_credit" sum="Total Credit" optional="hide"/>
                <field name="created_by"/>
                <field name="reconciliation_date"/>
            </tree>
        </field>
    </record>

    <record id="view_bank_reconciliation_master_form" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.form</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <form string="Bank Reconciliation">
                <header>
                    <button name="action_import_statement" string="Import Statement" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_process_matching" string="Process Matching" type="object"
                            class="btn-primary"
                            invisible="state != 'uploaded'"/>
                    <button name="action_master_reconcile" string="Master Reconcile" type="object"
                            class="btn-primary"
                            context="{'default_account_id': account_id}"
                            invisible="state != 'in_progress'"/>
                    <button name="action_validate_reconciliation" string="Validate &amp; Complete" type="object"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel_reconciliation" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state not in ['draft','uploaded','in_progress']"/>
                    <button name="action_view_move" string="View Journal Entry" type="object"
                            class="btn-info"
                            invisible="not move_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,uploaded,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="account_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="journal_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="posted_account_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="opening_balance"/>
                            <field name="total_debit"/>
                            <field name="total_credit"/>
                            <field name="total_amount" optional="hide"/>
                            <field name="closing_balance"/>
                            <field name="move_id" invisible="not move_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions">
                            <field name="transaction_ids">
                                <tree string="Transactions" editable="bottom">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="debit" sum="Total Debit"/>
                                    <field name="credit" sum="Total Credit"/>
                                    <field name="amount" optional="hide" sum="Net Total"/>
                                    <field name="reference"/>
                                    <field name="partner_id"/>
                                    <field name="account_id"/>
                                    <field name="state" widget="badge"/>
                                    <field name="confidence_level" widget="badge"/>
                                    <field name="match_score" optional="hide"/>
                                    <field name="matched_move_line_id" invisible="1"/>
                                    <field name="matched_move_id" invisible="1"/>
                                    <field name="matched_move_line_name" string="Matched Line" optional="show"/>
                                    <field name="matched_move_ref" string="Entry Ref" optional="show"/>
                                    <field name="matched_by_manual" widget="boolean_toggle" optional="hide"/>

                                    <!-- In the transactions tree view, add this button -->
                                    <button name="action_accept_match" type="object"
                                            string="Accept &amp; Reconcile" icon="fa-check"
                                            class="btn-success"
                                            invisible="state != 'matched'"/>

                                    <button name="action_accept_and_create_journal" type="object"
                                            string="Accept &amp; Create Journal" icon="fa-check-circle"
                                            class="btn-primary"
                                            invisible="state != 'matched'"/>
                                    <button name="action_view_related_move" type="object"
                                            string="View Entry" icon="fa-eye"
                                            invisible="not matched_move_id"/>
                                    <button name="action_view_related_move_line" type="object"
                                            string="View Line" icon="fa-list"
                                            invisible="not matched_move_line_id"/>
                                    <button name="action_manual_match" type="object"
                                            string="Manual Match" icon="fa-hand-pointer-o"
                                            invisible="state in ['reconciled']"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Reconciled" name="reconciled_page">
                            <field name="reconciled_ids">
                                <tree string="Reconciled Transactions">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="debit" sum="Total Debit"/>
                                    <field name="credit" sum="Total Credit"/>
                                    <field name="amount" optional="hide" sum="Net Total"/>
                                    <field name="account_id"/>
                                    <field name="confidence_level" widget="badge" optional="hide"/>
                                    <field name="match_score" optional="hide"/>
                                    <field name="matched_move_id"/>
                                    <field name="reconciled_by"/>
                                    <field name="reconciliation_date"/>
                                    <field name="is_posted" widget="boolean_toggle" optional="hide"/>
                                    <button name="action_view_move" type="object" string="View Entry" icon="fa-eye"/>
                                    <button name="action_unreconcile" type="object" string="Unreconcile" icon="fa-undo"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Statistics">
                            <group>
                                <group string="Transaction Summary">
                                    <field name="total_transactions" readonly="1"/>
                                    <field name="matched_transactions" readonly="1"/>
                                    <field name="unmatched_transactions" readonly="1"/>
                                    <field name="reconciled_transactions" readonly="1"/>
                                    <field name="pending_transactions" readonly="1"/>
                                    <field name="reconciliation_percentage" readonly="1" widget="progressbar"/>
                                </group>
                                <group string="Financial Summary">
                                    <field name="opening_balance" readonly="1"/>
                                    <field name="total_debit" readonly="1"/>
                                    <field name="total_credit" readonly="1"/>
                                    <field name="total_amount" readonly="1" optional="hide"/>
                                    <field name="closing_balance" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Matching Configuration" name="matching_config">
                            <group>
                                <group string="Matching Algorithm">
                                    <field name="matching_algorithm"/>
                                    <field name="match_tolerance_days"/>
                                    <field name="match_tolerance_amount"/>
                                </group>
                                <group string="Match Criteria">
                                    <field name="match_by_amount"/>
                                    <field name="match_by_reference"/>
                                    <field name="match_by_partner"/>
                                    <field name="match_by_invoice"/>
                                    <field name="match_by_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_bank_reconciliation_master_search" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.search</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="state"/>
                <filter name="state_draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="state_uploaded" string="Uploaded" domain="[('state','=','uploaded')]"/>
                <filter name="state_in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <filter name="state_completed" string="Completed" domain="[('state','=','completed')]"/>
                <filter name="state_cancelled" string="Cancelled" domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter name="has_reconciled" string="Has Reconciled" domain="[('reconciled_transactions','>',0)]"/>
                <filter name="has_unreconciled" string="Has Unreconciled" domain="[('unmatched_transactions','>',0)]"/>
                <filter name="has_journal_entry" string="Has Journal Entry" domain="[('move_id','!=',False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" domain="[]" context="{'group_by':'state'}"/>
                    <filter name="group_date" string="Date" domain="[]" context="{'group_by':'date'}"/>
                    <filter name="group_account" string="Account" domain="[]" context="{'group_by':'account_id'}"/>
                    <filter name="group_journal" string="Journal" domain="[]" context="{'group_by':'journal_id'}"/>
                    <filter name="group_created_by" string="Created By" domain="[]" context="{'group_by':'created_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bank_reconciliation_master" model="ir.actions.act_window">
        <field name="name">Bank Reconciliations</field>
        <field name="res_model">bank.reconciliation.master</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new bank reconciliation batch.
            </p>
        </field>
    </record>

    <menuitem id="menu_bank_reconciliation_root" 
              name="Bank Reconciliation" 
              sequence="10"
              parent="account.menu_finance"/>

    <menuitem id="menu_bank_reconciliation_master" 
              name="Bank Reconciliations" 
              parent="menu_bank_reconciliation_root"
              action="action_bank_reconciliation_master"
              sequence="10"/>

</odoo>