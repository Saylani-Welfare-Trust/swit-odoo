<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bank_reconciliation_master_tree" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.tree</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <tree string="Bank Reconciliations">
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="state" widget="badge"/>
                <field name="total_transactions"/>
                <field name="reconciled_transactions"/>
                <field name="reconciliation_percentage" widget="progressbar"/>
                <field name="created_by"/>
                <field name="reconciliation_date"/>
            </tree>
        </field>
    </record>

    <record id="view_bank_reconciliation_master_form" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.form</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <form string="Bank Reconciliation">
                <header>
                    <!-- NEW: Import Statement button (visible only in draft) -->
                    <button name="action_import_statement" string="Import Statement" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <!-- Existing buttons -->
                    <button name="action_process_matching" string="Process Matching" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_master_reconcile" string="Master Reconcile" type="object"
                            class="btn-primary"
                            context="{'default_account_id': account_id}"
                            invisible="state != 'in_progress'"/>
                    <button name="action_validate_reconciliation" string="Validate &amp; Complete" type="object"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel_reconciliation" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state not in ['draft','in_progress']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="opening_balance"/>
                            <field name="total_debit"/>
                            <field name="total_credit"/>
                            <field name="closing_balance"/>
                        </group>
                    </group>
                    <group>
                        <group string="File">
                            <field name="file" filename="file_name" required="1"/>
                            <field name="file_name" readonly="1"/>
                            <!-- <field name="file_type" readonly="1"/> -->
                            <!-- <field name="delimiter" invisible="file_type != 'csv'"/> -->
                        </group>
                    </group>
                    <notebook>
                        <page string="Transactions">
                            <field name="transaction_ids">
                                <tree string="Transactions" editable="bottom">
                                    <!-- All fields used in modifiers must be present -->
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="reference"/>
                                    <field name="partner_id"/>
                                    <field name="account_id"/>
                                    <field name="state" widget="badge"/>
                                    <field name="confidence_level" widget="badge"/>
                                    <field name="in_exception" widget="boolean_toggle"/>
                                    <field name="matched_move_id" invisible="1"/>

                                    <button name="action_accept_match" type="object"
                                            string="Accept" icon="fa-check"
                                            invisible="state != 'matched'"/>
                                    <button name="action_reject_match" type="object"
                                            string="Reject" icon="fa-times"
                                            invisible="state != 'matched'"/>
                                    <button name="action_manual_reconcile" type="object"
                                            string="Reconcile" icon="fa-exchange"
                                            invisible="state not in ['matched','unmatched']"/>
                                    <button name="action_view_related_move" type="object"
                                            string="View Entry" icon="fa-eye"
                                            invisible="not matched_move_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Reconciled" name="reconciled_page">
                            <field name="reconciled_ids">
                                <tree string="Reconciled Transactions">
                                    <field name="date"/>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="account_id"/>
                                    <field name="matched_move_id"/>
                                    <field name="reconciled_by"/>
                                    <field name="reconciliation_date"/>
                                    <button name="action_view_move" type="object" string="View Entry"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Statistics">
                            <group>
                                <field name="total_transactions" readonly="1"/>
                                <field name="matched_transactions" readonly="1"/>
                                <field name="unmatched_transactions" readonly="1"/>
                                <field name="reconciled_transactions" readonly="1"/>
                                <field name="pending_transactions" readonly="1"/>
                                <field name="reconciliation_percentage" readonly="1" widget="progressbar"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_bank_reconciliation_master_search" model="ir.ui.view">
        <field name="name">bank.reconciliation.master.search</field>
        <field name="model">bank.reconciliation.master</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="state"/>
                <filter name="state_draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="state_in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <filter name="state_completed" string="Completed" domain="[('state','=','completed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" domain="[]" context="{'group_by':'state'}"/>
                    <filter name="group_date" string="Date" domain="[]" context="{'group_by':'date'}"/>
                    <filter name="group_account" string="Account" domain="[]" context="{'group_by':'account_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bank_reconciliation_master" model="ir.actions.act_window">
        <field name="name">Bank Reconciliations</field>
        <field name="res_model">bank.reconciliation.master</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new bank reconciliation batch.
            </p>
        </field>
    </record>

</odoo>