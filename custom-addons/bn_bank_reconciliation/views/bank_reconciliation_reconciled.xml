<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bank_reconciliation_reconciled_tree" model="ir.ui.view">
        <field name="name">bank.reconciliation.reconciled.tree</field>
        <field name="model">bank.reconciliation.reconciled</field>
        <field name="arch" type="xml">
            <tree string="Reconciled Transactions">
                <field name="date"/>
                <field name="description"/>
                <field name="amount"/>
                <field name="account_id"/>
                <field name="matched_move_id"/>
                <field name="reconciled_by"/>
                <field name="reconciliation_date"/>
            </tree>
        </field>
    </record>

</odoo>