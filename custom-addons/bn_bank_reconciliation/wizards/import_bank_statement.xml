<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_import_bank_statement_wizard_form" model="ir.ui.view">
        <field name="name">import.bank.statement.wizard.form</field>
        <field name="model">import.bank.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement">
                <sheet>
                    <group>
                        <group>
                            <field name="master_id" invisible="1"/>
                            <field name="name" placeholder="Auto-generated if left empty"/>
                            <field name="date"/>
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="opening_balance"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                        <group string="File">
                            <field name="delimiter" invisible="file_type != 'csv'"/>
                            <field name="skip_first_row" invisible="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <p><strong>File Format Requirements</strong></p>
                        <ul>
                            <li>CSV or Excel (.xls, .xlsx)</li>
                            <li>Header row must contain: <strong>Date, Description, Amount, Reference, Payment Reference, Partner, Invoice Number</strong></li>
                            <li>Date format: YYYY-MM-DD or DD/MM/YYYY</li>
                            <li>Amount: numeric (decimal point)</li>
                            <li>Partner column can be empty</li>
                        </ul>
                        <p><i>For CSV, select the appropriate delimiter (comma, semicolon, or tab).</i></p>
                    </div>
                </sheet>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_bank_statement_wizard" model="ir.actions.act_window">
        <field name="name">Import Bank Statement</field>
        <field name="res_model">import.bank.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>