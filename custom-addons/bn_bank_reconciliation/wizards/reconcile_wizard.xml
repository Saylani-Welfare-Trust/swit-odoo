<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_reconcile_wizard_form" model="ir.ui.view">
        <field name="name">reconcile.wizard.form</field>
        <field name="model">reconcile.wizard</field>
        <field name="arch" type="xml">
            <form string="Reconciliation">
                <sheet>
                    <group>
                        <field name="master_id" invisible="1"/>
                        <field name="transaction_id" invisible="1"/>
                        <field name="account_id"/>
                    </group>
                    <group string="Filters">
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="partner_id"/>
                        <field name="show_only_matching_amount"/>
                    </group>
                    <notebook>
                        <page name="details" string="Details">
                            <field name="unreconciled_line_ids">
                                <tree string="Unreconciled Entries" editable="bottom">
                                    <field name="date"/>
                                    <field name="move_id"/>
                                    <field name="partner_id"/>
                                    <field name="name"/>
                                    <field name="balance"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                    <field name="currency_id"/>
                                    <field name="amount_currency"/>
                                </tree>
                            </field>

                            <field name="selected_line_ids">
                                <tree string="Selected Entries" create="0">
                                    <field name="date"/>
                                    <field name="move_id"/>
                                    <field name="partner_id"/>
                                    <field name="name"/>
                                    <field name="balance"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_reconcile" string="Reconcile" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reconcile_wizard" model="ir.actions.act_window">
        <field name="name">Reconcile</field>
        <field name="res_model">reconcile.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>