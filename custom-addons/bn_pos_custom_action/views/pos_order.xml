<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="point_of_sale_view_pos_pos_form_inherit_bn_pos_custom_action" model="ir.ui.view">
        <field name="name">point.of.sale.view.pos.pos.form.inherit.bn.pos.custom.action</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fiscal_position_id']" position="after">
                <field name="pos_cheque_order_id" invisible="1" readonly="1" />
                <field name="source_document" readonly="1" />
                <field name="receive_voucher" readonly="1" />
                <field name="qurbani" readonly="1" />
                <field name="pos_order_seq" readonly="1" />
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="point_of_sale_view_pos_order_tree_inherit_bn_pos_custom_action" model="ir.ui.view">
        <field name="name">point.of.sale.view.pos.order.tree.inherit.bn.pos.custom.action</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_reference']" position="after">
                <field name="pos_order_seq" />
            </xpath>
        </field>
    </record>

    <record id="point_of_sale_view_pos_order_filter_inherit_bn_pos_custom_action" model="ir.ui.view">
        <field name="name">point.of.sale.view.pos.order.filter.inherit.bn.pos.custom.action</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_reference']" position="after">
                <field name="pos_order_seq"/>
            </xpath>
        </field>
    </record>

</odoo>
