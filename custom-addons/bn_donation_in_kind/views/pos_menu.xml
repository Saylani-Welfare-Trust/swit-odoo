<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pos_donation_in_kind_action" model="ir.actions.act_window">
        <field name="name">Donation In Kind</field>
        <field name="res_model">donation.in.kind</field>
        <field name="view_mode">tree</field>
        <field name="context">{
            'create': 0,
            'edit': 0,
            'delete': 0
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new donation in kind...
            </p>
        </field>
    </record>

    <menuitem
        id="pos_donation_in_kind_menu"
        name="Donation In Kind"
        action="pos_donation_in_kind_action"
        parent="point_of_sale.menu_point_rep"
        sequence="10"/>

</odoo>
