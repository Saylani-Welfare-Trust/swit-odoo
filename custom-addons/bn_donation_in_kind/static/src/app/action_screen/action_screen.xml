<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="bn_donation_in_kind.DonationInKindButton" t-inherit="bn_pos_custom_action.ActionScreen" t-inherit-mode="extension">
        <xpath expr="//main" position="inside">
            <button class="btn btn-secondary btn-lg flex-fill py-4 d-flex align-items-center justify-content-center" t-on-click="() => this.clickRecordDonationInKind()">
                <i class="fa fa-box me-1 text-warning" role="img" aria-label="Donation In Kind" title="Donation In Kind" />
                Donation In Kind
            </button>
        </xpath>
    </t>

</templates>
