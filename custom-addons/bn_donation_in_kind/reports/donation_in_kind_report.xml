<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <!-- ===================== -->
        <!-- Direct Deposit Receipt -->
        <!-- ===================== -->
        <template id="bn_donation_in_kind.donation_in_kind_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <!-- PAGE WRAPPER -->
                        <div class="page" style="position:relative;">

                            <!-- ===== STYLES ===== -->
                            <style>
                                body {
                                    font-family: Arial, sans-serif;
                                    font-size: 11px;
                                }

                                h1 {
                                    font-size: 14px;
                                    font-weight: bold;
                                    margin: 2px 0;
                                }

                                h4 {
                                    font-size: 12px;
                                    margin: 6px 0;
                                    font-weight: bold;
                                }

                                table {
                                    font-size: 11px;
                                    border-collapse: collapse;
                                }

                                th, td {
                                    padding: 3px 4px !important;
                                }

                                /* ✅ FIXED WATERMARK */
                                .watermark {
                                    position: absolute; /* was fixed */
                                    top: 170px;         /* adjust if needed */
                                    left: 50%;
                                    transform: translateX(-50%) rotate(-30deg);
                                    font-size: 80px;
                                    color: rgba(200, 200, 200, 0.15);
                                    font-weight: bold;
                                    white-space: nowrap;
                                    pointer-events: none;
                                    z-index: 0;
                                }
                            </style>

                            <!-- ===== HEADER ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <h1>Donation Receipt</h1>
                                </div>
                                <div class="col-6 text-end">
                                    <h1>
                                        Saylani Welfare International Trust
                                        <t t-if="o.analytical_account_id">
                                            <br/>
                                            (<t t-esc="o.analytical_account_id.name"/>)
                                        </t>
                                    </h1>
                                </div>
                            </div>

                            <hr style="margin:4px 0"/>

                            <!-- ===== BASIC INFO ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <div><strong>DIK #:</strong> <t t-esc="o.name or '--'"/></div>
                                    <div name="donor_name"><strong>Register Name:</strong> <t t-esc="o.donor_id.name or '-'"/></div>
                                    <div><strong>CNIC No.:</strong> <t t-esc="o.donor_id.cnic_no or '-'"/></div>
                                    <div>
                                        <strong>Remarks:</strong>
                                        <t t-if="o.remarks">
                                            <t t-set="count" t-value="1"/>
                                            <t t-foreach="o.remarks.split('-')" t-as="remark">
                                                <t t-if="remark">
                                                    <t t-esc="count"/>. <t t-esc="remark or '-'"/>
                                                    <br/>
                                                    <t t-set="count" t-value="count + 1"/>
                                                </t>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="'-'"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date:</strong>
                                        <t t-esc="o.create_date.strftime('%d-%m-%Y %H:%M') if o.create_date else '--'"/>
                                    </div>
                                    <div>
                                        <strong>Contact No.:</strong>
                                        <t t-esc="o.donor_id.mobile or '-'"/>
                                    </div>
                                </div>
                            </div>

                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-end">Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.donation_in_kind_line_ids" t-as="line">
                                        <tr>
                                            <td><t t-esc="line.product_id.display_name"/></td>
                                            <td class="text-end"><t t-esc="'{:,}'.format(int(line.quantity) or 0) or 0"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <hr style="margin:4px 0"/>

                            <!-- ===== TOTALS ===== -->
                            <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px;">
                                <div>Entered by: <strong><t t-esc="o.create_uid.name"/></strong></div>
                            </div>

                            <hr style="margin:4px 0; border-top: solid 5px;"/>

                            <div class="row mb-2">
                                <div style="display: flex; margin-bottom: 5px; font-size: 12px;">
                                    
                                </div>

                                <div class="col-6">
                                    <div><strong>DIK #:</strong> <t t-esc="o.name or '--'"/></div>
                                    <div><strong>Register Name:</strong> <t t-esc="o.donor_id.name or '-'"/></div>
                                    <div>
                                        <t t-set="count" t-value="1"/>
                                        <strong>Products:</strong>
                                        <t t-foreach="o.donation_in_kind_line_ids" t-as="l">
                                            <div><t t-esc="count"/>. <t t-esc="l.product_id.display_name"/> - <t t-esc="'{:,}'.format(int(l.quantity) or 0) or 0"/></div>
                                            <t t-set="count" t-value="count + 1"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date &amp; Time:</strong>
                                        <t t-esc="o.create_date.strftime('%d-%m-%Y %H:%M') if o.create_date else '--'"/>
                                    </div>
                                    <div><strong>Entered by: </strong> <t t-esc="o.create_uid.name"/></div>
                                </div>
                            </div>

                            <div style="text-align: center; font-size: 12px;">
                                Powered by BytesNode
                            </div>

                        </div>

                    </t>
                </t>
            </t>
        </template>

        <record id="report_donation_in_kind_paperformat" model="report.paperformat">
            <field name="name">A5 - Donation In Kind Report</field>
            <field name="format">A5</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">84.67</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">4</field>
            <field name="margin_right">4</field>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_report_donation_in_kind" model="ir.actions.report">
            <field name="name">Donation In Kind Report</field>
            <field name="model">donation.in.kind</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bn_donation_in_kind.donation_in_kind_report</field>
            <field name="report_file">bn_donation_in_kind.donation_in_kind_report</field>
            <field name="binding_model_id" ref="bn_donation_in_kind.model_donation_in_kind"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Donation In Kind Report - %s' % (object.name)</field>
            <field name="paperformat_id" ref="bn_donation_in_kind.report_donation_in_kind_paperformat"/>
        </record>

    </data>
</odoo>