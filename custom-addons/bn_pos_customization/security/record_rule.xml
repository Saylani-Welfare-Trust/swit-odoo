<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pos_shop_rule" model="ir.rule">
        <field name="name">POS Shop User Only</field>
        <field name="model_id" ref="model_pos_config"/>
        <field name="domain_force">[('user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('bn_pos_customization.pos_shop_user_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="pos_order_rule" model="ir.rule">
        <field name="name">POS Order User Only</field>
        <field name="model_id" ref="point_of_sale.model_pos_order"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('bn_pos_customization.pos_shop_user_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <record id="pos_session_rule" model="ir.rule">
        <field name="name">POS Session User Only</field>
        <field name="model_id" ref="point_of_sale.model_pos_session"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('bn_pos_customization.pos_shop_user_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="pos_payment_rule" model="ir.rule">
        <field name="name">POS Payment User Only</field>
        <field name="model_id" ref="point_of_sale.model_pos_payment"/>
        <field name="domain_force">[('pos_order_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('bn_pos_customization.pos_shop_user_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
