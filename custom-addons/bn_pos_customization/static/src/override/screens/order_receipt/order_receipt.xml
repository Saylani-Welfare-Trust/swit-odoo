<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="bn_pos_customization.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt')]" position="replace">
            <div class="pos-receipt" style="page-break-inside: avoid; min-height: 0; font-family: Arial, sans-serif; margin-left:4px; margin-right:4px;">

                <t t-set="company" t-value="props.data.headerData.company"/>
                <t t-set="order" t-value="props.data"/>
                <t t-set="partner" t-value="props.data.partner"/>
                <t t-set="lines" t-value="props.data.orderlines"/>
                <t t-set="payment" t-value="props.data.paymentlines[0]"/>
                <t t-set="date_format" t-value="order.date" />
                <t t-set="format_currency_amount_zero" t-value="props.formatCurrency(0)" />
                <t t-set="format_currency_amount" t-value="props.formatCurrency(Math.round(order.amount_total))" />

                <!-- ===== HEADER ===== -->
                <div class="row" style="font-size: 14px; transform: scale(0.99); transform-origin: top; margin-bottom:4px;">
                    <div class="col-6">
                        <h1 class="fs-3 fw-bold text-uppercase" t-if="order.receive_voucher">Receipt Voucher</h1>
                        <h1 class="fs-3 fw-bold text-uppercase" t-if="!order.receive_voucher">Donation Receipt</h1>
                    </div>
                    <div class="col-6 text-end">
                        <b class="fw-bold text-uppercase">
                            <t t-if="company.name"><t t-esc="company.name"/></t>
                            <br/>
                            <t t-if="order.branch_name">(<t t-esc="order.branch_name"/>)</t>
                        </b>
                    </div>
                </div>

                <hr style="margin:4px 0"/>

                <!-- ===== DONOR & ORDER INFO ===== -->
                <div class="row" style="font-size: 12px; line-height: 1.1; margin-bottom:4px;">
                    <div class="col-6">
                        <div><strong>DN #:</strong> <t t-esc="order.branch_code or 'UNK'"/>-<t t-esc="company.name.substring(0,3).toUpperCase() or 'UNK'"/>-<t t-esc="new Date().getFullYear()"/>-<t t-esc="order.name.slice(-4)"/></div>
                        <div><strong>Donor Name:</strong> <t t-esc="partner.name or '-'"/></div>
                        <div><strong>CNIC No.:</strong> <t t-esc="partner.cnic_no or '-'"/></div>
                        <div><strong>Payment Method:</strong> <t t-esc="payment.name or '-'"/></div>
                        <t t-if="order.is_bank &amp;&amp; !order.is_donation_in_kind">
                            <div><strong>Bank Name:</strong> <t t-esc="order.bank_name"/></div>
                            <div><strong>Cheque No:</strong> <t t-esc="order.cheque_number"/></div>
                            <div><strong>Cheque Date:</strong> <t t-esc="order.cheque_date"/></div>
                        </t>
                        <t t-if="!order.is_bank &amp;&amp; !order.is_donation_in_kind">
                            <div><strong>Reference No:</strong> <t t-esc="order.qr_code"/></div>
                        </t>
                    </div>
                    <div class="col-6">
                        <div><strong>Date & Time:</strong> <t t-esc="new Date(date_format).toLocaleString()"/></div>
                        <div><strong>Contact No:</strong> <t t-esc="partner.mobile or partner.phone or '-'"/></div>
                        <div t-if="!order.is_donation_in_kind"><strong>Total Amount:</strong> <t t-esc="format_currency_amount"/></div>
                    </div>
                </div>

                <!-- ===== ITEMS TABLE ===== -->
                <table style="width:100%; font-size:12px; border-collapse:collapse; margin-bottom:4px;">
                    <thead>
                        <tr>
                            <th style="padding:2px 4px; text-align:left;">Product</th>
                            <th style="padding:2px 4px; text-align:right;">Qty</th>
                            <th style="padding:2px 4px; text-align:right;" t-if="!order.is_donation_in_kind">Rate</th>
                            <th style="padding:2px 4px; text-align:right;" t-if="!order.is_donation_in_kind">Amount</th>
                            <th style="padding:2px 4px; text-align:left;">Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="lines" t-as="line">
                            <tr>
                                <td style="padding:2px 4px;"><t t-esc="line.productName or '-'"/></td>
                                <td style="padding:2px 4px; text-align:right;"><t t-esc="line.qty or '-'"/></td>
                                <td style="padding:2px 4px; text-align:right;" t-if="!order.is_donation_in_kind"><t t-esc="line.unitPrice or '-'"/></td>
                                <td style="padding:2px 4px; text-align:right;" t-if="!order.is_donation_in_kind"><t t-esc="line.price or '-'"/></td>
                                <td style="padding:2px 4px;"><t t-esc="line.customerNote or '-'"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <hr style="margin:4px 0"/>

                <!-- ===== FOOTER ===== -->
                <div style="display:flex; justify-content:space-between; font-size:11px; margin-bottom:4px;">
                    <div>Entered by: <strong><t t-esc="order.cashier"/></strong></div>
                    <div>Total Amount: <strong><t t-esc="format_currency_amount"/></strong></div>
                </div>

                <div style="text-align:center; font-size:10px;">Powered by BytesNode</div>

            </div>
        </xpath>
    </t>

</templates>