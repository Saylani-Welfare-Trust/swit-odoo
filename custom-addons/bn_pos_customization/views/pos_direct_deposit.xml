<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="pos_direct_deposit_action" model="ir.actions.act_window">
        <field name="name">Action Name</field>
        <field name="res_model">direct.deposit</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('user_id', '=', user.id)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for direct depsoit records....
            </p>
        </field>
    </record>

    <menuitem
        id="pos_direct_deposit_menu"
        name="Direct Deposit"
        action="pos_direct_deposit_action"
        parent="point_of_sale.menu_point_rep"
        sequence="10"/>

</odoo>
