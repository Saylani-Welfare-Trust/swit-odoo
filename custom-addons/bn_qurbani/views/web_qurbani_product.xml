<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="web_qurbani_product_tree_view" model="ir.ui.view">
        <field name="name">web.qurbani.product.tree.view</field>
        <field name="model">web.qurbani.product</field>
        <field name="arch" type="xml">
            <tree editable="bottom" string="Web Qurbani Product">
                <field name="name"/>
                <field name="product_id"/>
            </tree>
        </field>
    </record>

    <record id="action_web_qurbani_product" model="ir.actions.act_window">
        <field name="name">Web Qurbani Product</field>
        <field name="res_model">web.qurbani.product</field>
        <field name="view_mode">tree</field>
    </record>
    <menuitem id="menu_qurbani_hijri"
          name="Web Qurbani Products"
          parent="qurbani_menu"
          action="action_web_qurbani_product"
          sequence="1"/>
</odoo>
