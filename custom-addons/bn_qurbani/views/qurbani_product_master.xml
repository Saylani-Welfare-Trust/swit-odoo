<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_product_master_view_tree" model="ir.ui.view">
        <field name="name">qurbani.product.master.view.tree</field>
        <field name="model">qurbani.product.master</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="inventory_product_name" column_invisible="1" />

                <field name="inventory_product_id" domain="[('type', '=', 'product'), ('is_qurbani_inventory', '=', True), ('is_livestock', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                <field name="pos_product_ids" widget="many2many_tags"  domain="[('name', 'ilike', inventory_product_name), ('type', '=', 'product'), ('is_pos_qurbani_inventory', '=', True), ('is_livestock', '=', True)]" required="1"/>
            </tree>
        </field>
    </record>

    <record id="qurbani_product_master_action" model="ir.actions.act_window">
        <field name="name">Product Master</field>
        <field name="res_model">qurbani.product.master</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new master product configuration....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_product_master_menu"
        name="Product Master"
        action="qurbani_product_master_action"
        parent="bn_qurbani.qurbani_menu"
        sequence="5"/>

</odoo>
