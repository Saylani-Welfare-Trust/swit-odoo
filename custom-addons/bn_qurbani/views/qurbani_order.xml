<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_qurbani_order_tree" model="ir.ui.view">
        <field name="name">qurbani.order.tree</field>
        <field name="model">qurbani.order</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="pos_order_id"/>
                <field name="receipt_number"/>
                <field name="product_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <record id="action_qurbani_order" model="ir.actions.act_window">
        <field name="name">Qurbani Order</field>
        <field name="res_model">qurbani.order</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_qurbani_order"
        name="Qurbani Orders"
        parent="menu_qurbani_root"
        action="action_qurbani_order"
        sequence="30"/>
</odoo>