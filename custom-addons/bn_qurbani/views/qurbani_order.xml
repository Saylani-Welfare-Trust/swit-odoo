<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_order_view_tree" model="ir.ui.view">
        <field name="name">qurbani.order.view.tree</field>
        <field name="model">qurbani.order</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" default_order="create_date desc">
                <field name="name"/>
                <field name="donor_id"/>
                <field name="amount" sum="1" />
                <field name="total_amount" sum="1" />
            </tree>
        </field>
    </record>

    <record id="qurbani_order_view_form" model="ir.ui.view">
        <field name="name">qurbani.order.view.form</field>
        <field name="model">qurbani.order</field>
        <field name="arch" type="xml">
            <form create="0" edit="1">
                <header>
                    <button string="Show POS Order" name="action_show_pos_order" type="object" class="oe_highlight" invisible="pos_qurbani_order != True"/>
                </header>
                
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Qurbani Order" />
                        <h1><field name="name" readonly="1" /></h1>
                    </div>

                    <!-- Hidden field for controlling visibility -->
                    <field name="pos_qurbani_order" invisible="1" />
                    <field name="currency_id" invisible="1"/>

                    <!-- POS Order Section (shown when pos_qurbani_order = True) -->
                    <group invisible="pos_qurbani_order != True">
                        <h2>POS Order Information</h2>
                        <group>
                            <field name="donor_id" string="Donor" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                            <label for="mobile"/>
                            <div style="display: flex;">
                                <field options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" style="width: 30% !important;" name="country_code_id" nolabel="1" /> 
                                <field style="width: 70% !important;" name="mobile" readonly="1" nolabel="1" />
                            </div>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- General Information (Both POS and Web) -->
                    <group string="Additional Information">
                        <field name="remarks" />
                        <field name="amount" />
                        <field name="total_amount" />
                    </group>

                    <notebook>
                        <page string="Items">
                            <field name="qurbani_order_line_ids">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="name" readonly="1" />
                                    <field name="day_id" options="{'no_quick_create': True, 'no_create_edit': True}" readonly="1" />
                                    <field name="hijri_id" options="{'no_quick_create': True, 'no_create_edit': True}" readonly="1" />
                                    <field name="hissa_name" />
                                    <field name="start_time" widget="float_time" readonly="1" />
                                    <field name="end_time" widget="float_time" readonly="1" />
                                    <field name="currency_id" column_invisible="1" readonly="1" />
                                    <field name="product_id" options="{'no_quick_create': True, 'no_create_edit': True}" readonly="1" />
                                    <field name="quantity" readonly="1" />
                                    <field name="amount" readonly="1" />
                                    <field name="city_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                                    <field name="distribution_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action for POS Qurbani Orders (field = True) -->
    <record id="action_pos_qurbani_order" model="ir.actions.act_window">
        <field name="name">POS Qurbani Orders</field>
        <field name="res_model">qurbani.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('pos_qurbani_order', '=', True)]</field>   <!-- corrected field name -->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                List of Qurbani orders created from POS.
            </p>
        </field>
    </record>

    <!-- Action for Web Qurbani Orders (field = False) -->
    <record id="action_web_qurbani_order" model="ir.actions.act_window">
        <field name="name">Web Qurbani Orders</field>
        <field name="res_model">qurbani.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('pos_qurbani_order', '=', False)]</field>   <!-- corrected field name -->
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                List of Qurbani orders created from Web.
            </p>
        </field>
    </record>

    <menuitem id="menu_qurbani_root"
        name="Qurbani"
        groups="bn_qurbani.qurbani_menu_group"
        web_icon="bn_qurbani,static/description/icon.png"
        sequence="10"/>

    <menuitem id="menu_qurbani_order"
        name="Qurbani Order"
        parent="menu_qurbani_root"
        sequence="1"
        groups="bn_qurbani.qurbani_menu_group"/>

    <!-- Make POS Qurbani Order the default by giving it the smallest sequence -->
    <menuitem id="menu_pos_qurbani_order"
        name="POS Qurbani Order"
        parent="menu_qurbani_order"
        action="action_pos_qurbani_order"
        sequence="1"
        groups="bn_qurbani.qurbani_menu_group"/>

    <menuitem id="menu_web_qurbani_order"
        name="Web Qurbani Order"
        parent="menu_qurbani_order"
        action="action_web_qurbani_order"
        sequence="2"
        groups="bn_qurbani.qurbani_menu_group"/>


</odoo>