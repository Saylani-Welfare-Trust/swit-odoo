<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="slaughter_schedule_view_tree" model="ir.ui.view">
        <field name="name">slaughter.schedule.view.tree</field>
        <field name="model">slaughter.schedule</field>
        <field name="arch" type="xml">
            <tree create="0" editable="bottom">
                <field name="slaughter_location_ids" column_invisible="1"/>
                <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                <field name="start_time" widget="float_time" required="1"/>
                <field name="end_time" widget="float_time" required="1"/>
                <field name="city_schedule_id" required="1" domain="[('hijri_id', '=', hijri_id), ('day_id', '=', day_id)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                <field name="location_id" required="1" domain="[('id', 'in', slaughter_location_ids)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
                <field name="demand" required="1"/>
                <field name="location_ids" widget="many2many_tags" domain="[('is_distribution_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
            </tree>
        </field>
    </record>

    <record id="slaughter_schedule_action" model="ir.actions.act_window">
        <field name="name">Slaughter Schedule</field>
        <field name="res_model">slaughter.schedule</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new slaughter schedule....
            </p>
        </field>
    </record>

    <menuitem
        id="slaughter_schedule_menu"
        name="Slaughter"
        action="slaughter_schedule_action"
        parent="bn_qurbani.qurbani_schedule_menu"
        sequence="1"/>

</odoo>
