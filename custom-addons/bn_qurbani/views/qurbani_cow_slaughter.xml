<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_cow_slaughter_view_tree" model="ir.ui.view">
        <field name="name">qurbani.cow.slaughter.view.tree</field>
        <field name="model">qurbani.cow.slaughter</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" editable="bottom">
                <field name="video_file_name" column_invisible="1" />
                <field name="image_file_name" column_invisible="1" />

                <field name="qurbani_order_no" readonly="1" />
                <field name="qurbani_order_line_no" readonly="1" />
                <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="slaughter_location_id" domain="[('is_slaughter_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="start_time" widget="float_time" readonly="1" />
                <field name="end_time" widget="float_time" readonly="1" />
                <field name="hissa_name" readonly="1" />

                <field name="video" filename="video_file_name" />
                <field name="image" filename="image_file_name" />
            </tree>
        </field>
    </record>

    <record id="qurbani_cow_slaughter_action" model="ir.actions.act_window">
        <field name="name">Cow</field>
        <field name="res_model">qurbani.cow.slaughter</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for new qurbani cow slaughter....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_slaughter_root_menu"
        name="Slaughter"
        parent="bn_qurbani.menu_qurbani_root"
        sequence="3"/>

    <menuitem
        id="qurbani_cow_slaughter_menu"
        name="Cow"
        action="qurbani_cow_slaughter_action"
        parent="qurbani_slaughter_root_menu"
        sequence="0"/>

</odoo>
