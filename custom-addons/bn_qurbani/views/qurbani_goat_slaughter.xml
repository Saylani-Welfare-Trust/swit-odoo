<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_goat_slaughter_view_tree" model="ir.ui.view">
        <field name="name">qurbani.goat.slaughter.view.tree</field>
        <field name="model">qurbani.goat.slaughter</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" editable="bottom">
                <header>
                    <button string="Print" name="action_print_report" type="object" class="oe_highlight"/>
                </header>

                <field name="video_file_name" column_invisible="1" />
                <field name="image_file_name" column_invisible="1" />

                <field name="name" readonly="1" />
                <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="start_time" widget="float_time" readonly="1" />
                <field name="end_time" widget="float_time" readonly="1" />
                <field name="slaughter_location_id" string="Location" domain="[('is_slaughter_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>

                <field name="qurbani_order_no" readonly="1" />
                <field name="qurbani_order_line_no" readonly="1" />
                <field name="product_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                <field name="hissa_name" readonly="1" />

                <field name="video" filename="video_file_name" />
                <field name="image" filename="image_file_name" />

                <field name="state" widget="badge" decoration-info="state == 'available'" decoration-success="state == 'full'" />

                <button string="Transfer" name="action_transfer" type="object" class="oe_highlight"/>
            </tree>
        </field>
    </record>

    <record id="qurbani_goat_slaughter_view_search" model="ir.ui.view">
        <field name="name">qurbani.goat.slaughter.view.search</field>
        <field name="model">qurbani.goat.slaughter</field>
        <field name="arch" type="xml">
            <search>
                <filter name="start_time" string="Start Time" context="{'group_by': 'start_time'}" />
                <filter name="end_time" string="End Time" context="{'group_by': 'end_time'}" />
            </search>
        </field>
    </record>

    <record id="qurbani_goat_slaughter_action" model="ir.actions.act_window">
        <field name="name">Goat Slaughter</field>
        <field name="res_model">qurbani.goat.slaughter</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for new qurbani goat slaughter....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_goat_slaughter_menu"
        name="Goat"
        action="qurbani_goat_slaughter_action"
        parent="bn_qurbani.qurbani_slaughter_root_menu"
        sequence="1"/>

</odoo>
