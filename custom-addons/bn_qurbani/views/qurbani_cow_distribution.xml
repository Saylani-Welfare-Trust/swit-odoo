<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_cow_distribution_view_tree" model="ir.ui.view">
        <field name="name">qurbani.cow.distribution.view.tree</field>
        <field name="model">qurbani.cow.distribution</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0">
                <field name="video_file_name" column_invisible="1" />
                <field name="image_file_name" column_invisible="1" />

                <field name="name" readonly="1" />
                <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="start_time" widget="float_time" readonly="1" />
                <field name="end_time" widget="float_time" readonly="1" />
                <field name="distribution_location_id" domain="[('is_distribution_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>

                <field name="video" filename="video_file_name" />
                <field name="image" filename="image_file_name" />
            </tree>
        </field>
    </record>

    <record id="qurbani_cow_distribution_view_form" model="ir.ui.view">
        <field name="name">qurbani.cow.distribution.view.form</field>
        <field name="model">qurbani.cow.distribution</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Distribution Sequence" />
                        <h1><field name="name" readonly="1" /></h1>
                    </div>

                    <group>
                        <group name="qurbani_cow_distribution_col_1">
                            <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                            <field name="start_time" widget="float_time" readonly="1" />
                            <field name="video" filename="video_file_name" />
                            <field name="distribution_location_id" domain="[('is_distribution_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                        </group>
                        <group name="qurbani_cow_distribution_col_2">
                            <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                            <field name="end_time" widget="float_time" readonly="1" />
                            <field name="image" filename="image_file_name" />
                        </group>
                    </group>

                    <notebook>
                        <page name="qurbani_order" string="Qurbani Order">
                            <field name="qurbani_cow_distribution_line" readonly="1">
                                <tree>
                                    <field name="qurbani_order_no" />
                                    <field name="qurbani_order_line_no" />
                                    <field name="hissa_name" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="qurbani_cow_distribution_action" model="ir.actions.act_window">
        <field name="name">Cow</field>
        <field name="res_model">qurbani.cow.distribution</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for new qurbani cow distribution....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_distribution_root_menu"
        name="Distribution"
        parent="bn_qurbani.menu_qurbani_root"
        sequence="3"/>

    <menuitem
        id="qurbani_cow_distribution_menu"
        name="Cow"
        action="qurbani_cow_distribution_action"
        parent="qurbani_distribution_root_menu"
        sequence="0"/>

</odoo>
