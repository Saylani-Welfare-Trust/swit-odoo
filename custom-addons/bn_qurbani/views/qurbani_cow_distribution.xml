<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_cow_distribution_view_tree" model="ir.ui.view">
        <field name="name">qurbani.cow.distribution.view.tree</field>
        <field name="model">qurbani.cow.distribution</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0" editable="bottom">
                <header>
                    <button string="Print" name="action_print_report" type="object" class="oe_highlight"/>
                </header>

                <field name="name" readonly="1" />
                <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                <field name="slaughter_start_time" widget="float_time" readonly="1" />
                <field name="slaughter_end_time" widget="float_time" readonly="1" />
                <field name="slaughter_location_id" domain="[('is_slaughter_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>
                <field name="start_time" widget="float_time" readonly="1" />
                <field name="end_time" widget="float_time" readonly="1" />
                <field name="distribution_location_id" domain="[('is_distribution_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1"/>

                <field name="qurbani_order_no" readonly="1" />
                <field name="qurbani_order_line_no" readonly="1" />
                <field name="product_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="1" />
                <field name="hissa_name" readonly="1" />
                <field name="remarks" />

                <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-info="state not in ['pending', 'delivered']" decoration-success="state == 'delivered'" />

                <button string="Approve" name="action_approved" type="object" class="oe_highlight"/>
            </tree>
        </field>
    </record>

    <record id="qurbani_cow_distribution_action" model="ir.actions.act_window">
        <field name="name">Cow Distribution</field>
        <field name="res_model">qurbani.cow.distribution</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for new qurbani cow distribution....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_distribution_root_menu"
        name="Distribution"
        parent="bn_qurbani.menu_qurbani_root"
        sequence="3"/>

    <menuitem
        id="qurbani_cow_distribution_menu"
        name="Cow"
        action="qurbani_cow_distribution_action"
        parent="qurbani_distribution_root_menu"
        sequence="0"/>

</odoo>
