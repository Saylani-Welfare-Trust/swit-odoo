<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="qurbani_day_view_tree" model="ir.ui.view">
        <field name="name">qurbani.day.view.tree</field>
        <field name="model">qurbani.day</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="name" />
            </tree>
        </field>
    </record>


    <record id="qurbani_day_action" model="ir.actions.act_window">
        <field name="name">Qurbani Day</field>
        <field name="res_model">qurbani.day</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new qurbani day....
            </p>
        </field>
    </record>

    <menuitem
        id="qurbani_menu"
        name="Qurbani"
        action="qurbani_day_action"
        parent="bn_master_setup.master_setup_menu"
        sequence="10"/>

    <menuitem
        id="qurbani_day_menu"
        name="Day"
        action="qurbani_day_action"
        parent="bn_qurbani.qurbani_menu"
        sequence="10"/>

</odoo>
