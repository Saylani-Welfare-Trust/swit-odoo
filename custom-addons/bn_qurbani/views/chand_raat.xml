<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="chand_raat_view_tree" model="ir.ui.view">
        <field name="name">chand.raat.view.tree</field>
        <field name="model">chand.raat</field>
        <field name="arch" type="xml">
            <tree editable="bottom" create="0" delete="0">
                <field name="date_time" />
            </tree>
        </field>
    </record>

    <record id="chand_raat_action" model="ir.actions.act_window">
        <field name="name">Chand Raat</field>
        <field name="res_model">chand.raat</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new chand raat....
            </p>
        </field>
    </record>

    <menuitem
        id="chand_raat_menu"
        name="Chand Raat"
        action="chand_raat_action"
        parent="bn_qurbani.qurbani_menu"
        sequence="10"/>

</odoo>
