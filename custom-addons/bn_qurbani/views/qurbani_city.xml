<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="web_qurbani_city" model="ir.ui.view">
        <field name="name">web.qurbani.city.tree.view</field>
        <field name="model">qurbani.city</field>
        <field name="arch" type="xml">
            <tree editable="bottom" string="Web Qurbani City">
                <field name="name"/>
                <field name="city_id"  options="{'no_create': True, 'no_edit': True, 'no_open': True}"/>
            </tree>
        </field>
    </record>

    <record id="action_qurbani_city" model="ir.actions.act_window">
        <field name="name">Web Qurbani City</field>
        <field name="res_model">qurbani.city</field>
        <field name="view_mode">tree</field>
    </record>
    

    <menuitem id="menu_qurbani_city"
          name="Web Qurbani City"
          parent="menu_qurbani_Web"
          action="action_qurbani_city"
          sequence="1"
           />

</odoo>
