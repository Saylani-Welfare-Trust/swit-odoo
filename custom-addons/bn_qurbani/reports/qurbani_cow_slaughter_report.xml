<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_cow_slaughter_report_template">
        <t t-call="web.html_container">

            <style>
                .page {
                    padding: 0px !important;
                    margin: 0px !important;
                    page-break-inside: avoid;
                }

                table {
                    margin: 0px !important;
                    padding: 0px !important;
                    border-spacing: 0 !important;
                }

                td, th {
                    padding: 2px !important;
                }

                .row {
                    margin: 0px !important;
                    padding: 0px !important;
                }

                .col-3 {
                    padding: 0px !important;
                }
            </style>

            <t t-call="web.external_layout">

                <!-- COUNTER -->
                <t t-set="count" t-value="1"/>

                <t t-foreach="docs" t-as="o">

                    <!-- APPLY PAGE BREAK AFTER EVERY 5 RECORDS -->
                    <div class="page"
                        t-att-style="'page-break-after: always;' if count % 5 == 0 else ''">

                        <!-- HEADER -->
                        <div class="row">
                            <div class="col-2">
                                <strong><span t-esc="o.name"/></strong>
                            </div>

                            <div class="col-6">
                                <strong>
                                    <span>Location</span> -
                                    <span t-esc="o.slaughter_location_id.name"/>
                                </strong>
                            </div>

                            <div class="col-2">
                                <strong>
                                    <span>Start Time</span>
                                    <span t-esc="o.start_time" widget="float_time"/>
                                </strong>
                            </div>

                            <div class="col-2">
                                <strong>
                                    <span>End Time</span>
                                    <span t-esc="o.end_time" widget="float_time"/>
                                </strong>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-2">
                                <strong>SO No.</strong>
                            </div>

                            <div class="col-6">
                                <strong>Hissa Name</strong>
                            </div>

                            <div class="col-4">
                                <strong>QO No.</strong>
                            </div>
                        </div>
                        
                        <t t-set="line_count" t-value="1"/>

                        <t t-foreach="o.qurbani_cow_slaughter_line" t-as="line">
                            <div class="row" style="font-size: 11px; margin: 0; padding: 0;">
                                <div class="col-2">
                                    <t t-esc="line_count"/>
                                </div>

                                <div class="col-6">
                                    <t t-esc="line.hissa_name"/>
                                </div>

                                <div class="col-4">
                                    <t t-esc="line.qurbani_order_no"/>
                                </div>
                            </div>
                            <t t-set="line_count" t-value="line_count + 1"/>
                        </t>
                        
                    </div>

                    <!-- INCREMENT MAIN COUNTER -->
                    <t t-set="count" t-value="count + 1"/>

                </t>

            </t>
        </t>
    </template>

    <record id="qurbani_cow_slaughter_paperformat" model="report.paperformat">
        <field name="name">A4 - Qurbani Cow Slaughter</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">40</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">9</field>
        <field name="dpi">90</field>
    </record>

    <record id="qurbani_cow_slaughter_report" model="ir.actions.report">
        <field name="name">Qurbani Cow Slaughter</field>
        <field name="model">qurbani.cow.slaughter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="report_file">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="binding_model_id" ref="bn_qurbani.model_qurbani_cow_slaughter"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="qurbani_cow_slaughter_paperformat"/>
    </record>

</odoo>
