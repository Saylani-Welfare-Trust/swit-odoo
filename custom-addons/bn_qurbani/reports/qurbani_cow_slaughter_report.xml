<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_cow_slaughter_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <div class="page">
                        <h2><span t-esc="o.name"/></h2>

                        <div class="row">
                            <div class="col-6">
                                <span>Location</span> - <spna><t t-esc="o.slaughter_location_id.name"/></spna>
                            </div>
                            <div class="col-6"/>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <span>Start Time</span> <spna><t t-esc="o.start_time"/></spna>
                            </div>
                            <div class="col-6">
                                <span>End Time</span> <spna><t t-esc="o.end_time"/></spna>
                            </div>
                        </div>

                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>QO No.</th>
                                    <th>QOL No.</th>
                                    <th>Product</th>
                                    <th>Hissa Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.qurbani_cow_slaughter_line" t-as="line" t-key="line.id">
                                    <tr>
                                        <td><t t-esc="line.qurbani_order_no"/></td>
                                        <td><t t-esc="line.qurbani_order_line_no"/></td>
                                        <td><t t-esc="line.product_id.name"/></td>
                                        <td><t t-esc="line.hissa_name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="qurbani_cow_slaughter_report" model="ir.actions.report">
        <field name="name">Qurbani Cow Slaughter</field>
        <field name="model">qurbani.cow.slaughter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="report_file">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="binding_model_id" ref="bn_qurbani.model_qurbani_cow_slaughter"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
