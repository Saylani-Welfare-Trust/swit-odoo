<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_cow_slaughter_report_template">
        <t t-call="web.html_container">

            <style>
                .page {
                    page-break-after: always;
                    padding: 10px;
                    font-size: 11px;
                }

                .cow-box {
                    width: 48%;
                    display: inline-block;
                    vertical-align: top;
                    border: 1px solid #000;
                    padding: 6px;
                    margin-bottom: 10px;
                }

                .cow-row {
                    width: 100%;
                    display: flex;
                    justify-content: space-between;
                    margin-bottom: 10px;
                }
            </style>

            <t t-call="web.external_layout">

                <!-- PAGE LOOP (5 records per page) -->
                <t t-set="total" t-value="len(docs)"/>

                <t t-foreach="range(0, total, 5)" t-as="i">

                    <div class="page">

                        <!-- Slice 5 cows -->
                        <t t-set="page_docs" t-value="docs[i:i+5]"/>

                        <!-- ROW 1 (Cow 1 & 2) -->
                        <t t-if="len(page_docs) > 0">
                            <div class="cow-row">

                                <div class="cow-box">
                                    <strong t-esc="page_docs[0].name"/>
                                    <div>Location: <t t-esc="page_docs[0].slaughter_location_id.name"/></div>
                                    <div>Start: <t t-esc="page_docs[0].start_time" widget="float_time"/></div>
                                    <div>End: <t t-esc="page_docs[0].end_time" widget="float_time"/></div>
                                </div>

                                <t t-if="len(page_docs) > 1">
                                    <div class="cow-box">
                                        <strong t-esc="page_docs[1].name"/>
                                        <div>Location: <t t-esc="page_docs[1].slaughter_location_id.name"/></div>
                                        <div>Start: <t t-esc="page_docs[1].start_time" widget="float_time"/></div>
                                        <div>End: <t t-esc="page_docs[1].end_time" widget="float_time"/></div>
                                    </div>
                                </t>

                            </div>
                        </t>

                        <!-- ROW 2 (Cow 3 & 4) -->
                        <t t-if="len(page_docs) > 2">
                            <div class="cow-row">

                                <div class="cow-box">
                                    <strong t-esc="page_docs[2].name"/>
                                    <div>Location: <t t-esc="page_docs[2].slaughter_location_id.name"/></div>
                                    <div>Start: <t t-esc="page_docs[2].start_time" widget="float_time"/></div>
                                    <div>End: <t t-esc="page_docs[2].end_time" widget="float_time"/></div>
                                </div>

                                <t t-if="len(page_docs) > 3">
                                    <div class="cow-box">
                                        <strong t-esc="page_docs[3].name"/>
                                        <div>Location: <t t-esc="page_docs[3].slaughter_location_id.name"/></div>
                                        <div>Start: <t t-esc="page_docs[3].start_time" widget="float_time"/></div>
                                        <div>End: <t t-esc="page_docs[3].end_time" widget="float_time"/></div>
                                    </div>
                                </t>

                            </div>
                        </t>

                        <!-- ROW 3 (Cow 5 only) -->
                        <t t-if="len(page_docs) > 4">
                            <div class="cow-row">
                                <div class="cow-box" style="width: 100%;">
                                    <strong t-esc="page_docs[4].name"/>
                                    <div>Location: <t t-esc="page_docs[4].slaughter_location_id.name"/></div>
                                    <div>Start: <t t-esc="page_docs[4].start_time" widget="float_time"/></div>
                                    <div>End: <t t-esc="page_docs[4].end_time" widget="float_time"/></div>
                                </div>
                            </div>
                        </t>

                    </div>

                </t>

            </t>
        </t>
    </template>

    <record id="qurbani_cow_slaughter_paperformat" model="report.paperformat">
        <field name="name">A4 - Qurbani Cow Slaughter</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="qurbani_cow_slaughter_report" model="ir.actions.report">
        <field name="name">Qurbani Cow Slaughter</field>
        <field name="model">qurbani.cow.slaughter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="report_file">bn_qurbani.qurbani_cow_slaughter_report_template</field>
        <field name="binding_model_id" ref="bn_qurbani.model_qurbani_cow_slaughter"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="qurbani_cow_slaughter_paperformat"/>
    </record>

</odoo>
