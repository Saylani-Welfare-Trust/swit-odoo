<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_goat_slaughter_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">

                <!-- COUNTER -->
                <t t-set="count" t-value="1"/>

                <t t-foreach="docs" t-as="o">
                    <div class="page"
                        t-att-style="'page-break-after: always;' if count % 10 == 0 else ''">

                        <t t-if="(count - 1) % 10 == 0">
                            <!-- HEADER ONLY ON PAGE START -->
                            <h2>Saylani Welfare and International Trust</h2>
                            <h3>Goat Slaughter Schedule Report</h3>
                        </t>

                       <br/>

                        <!-- HEADER -->
                        <div class="row">
                            <div class="col-2">
                                <strong><span t-esc="o.name"/></strong>
                            </div>

                            <div class="col-6">
                                <strong>
                                    <span>Location</span> -
                                    <span t-esc="o.slaughter_location_id.name"/>
                                </strong>
                            </div>

                            <div class="col-2">
                                <strong>
                                    <span>Start Time</span>
                                    <span t-esc="o.start_time" widget="float_time"/>
                                </strong>
                            </div>

                            <div class="col-2">
                                <strong>
                                    <span>End Time</span>
                                    <span t-esc="o.end_time" widget="float_time"/>
                                </strong>
                            </div>
                        </div>

                        <br/>
                        
                        <div class="row">
                            <div class="col-6">
                                <strong>Hissa Name</strong>
                            </div>

                            <div class="col-4">
                                <strong>QO No.</strong>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <t t-esc="o.hissa_name"/>
                            </div>

                            <div class="col-4">
                                <t t-esc="o.qurbani_order_no"/>
                            </div>
                        </div>
                      
                    </div>

                    <!-- INCREMENT MAIN COUNTER -->
                    <t t-set="count" t-value="count + 1"/>
                </t>
            </t>
        </t>
    </template>

    <record id="qurbani_goat_slaughter_paperformat" model="report.paperformat">
        <field name="name">A4 - Qurbani Goat Slaughter</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">9</field>
    </record>

    <record id="qurbani_goat_slaughter_report" model="ir.actions.report">
        <field name="name">Qurbani Goat Slaughter</field>
        <field name="model">qurbani.goat.slaughter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_qurbani.qurbani_goat_slaughter_report_template</field>
        <field name="report_file">bn_qurbani.qurbani_goat_slaughter_report_template</field>
        <field name="binding_model_id" ref="bn_qurbani.model_qurbani_goat_slaughter"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="qurbani_goat_slaughter_paperformat"/>
    </record>

</odoo>
