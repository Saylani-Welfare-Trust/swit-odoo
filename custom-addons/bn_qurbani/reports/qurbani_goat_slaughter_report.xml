<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_goat_slaughter_report">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="count" t-value="0"/>

                <t t-foreach="docs" t-as="o">
                    <t t-set="count" t-value="count + 1"/>

                    <div class="page">
                        <h2><span t-esc="o.name"/></h2>

                        <div class="row">
                            <div class="col-6">
                                <span>Location</span> <spna><t t-esc="o.slaughter_location_id.name"/></spna>
                            </div>
                            <div class="col-6">
                                <span>QO No.</span> <spna><t t-esc="o.qurbani_order_no"/></spna>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <span>QOL No.</span> <spna><t t-esc="o.qurbani_order_line_no"/></spna>
                            </div>
                            <div class="col-6">
                                <span>Product</span> <spna><t t-esc="o.product_id.name"/></spna>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <span>Hissa Name</span> <spna><t t-esc="o.hissa_name"/></spna>
                            </div>
                            <div class="col-6"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
