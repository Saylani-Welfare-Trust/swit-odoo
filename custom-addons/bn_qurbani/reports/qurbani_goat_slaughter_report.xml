<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_qurbani.qurbani_goat_slaughter_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <h2>Saylani International And Welfare Trust</h2>
                <h3>Cow Slaughter Schedule Report</h3>

                <t t-foreach="docs" t-as="o">
                    <div class="page">

                        <div class="row">
                            <div class="col-4">
                                <span t-esc="o.name"/>
                            </div>
                            <div class="col-4">
                                <span>Hissa Name</span> <spna><t t-esc="o.hissa_name"/></spna>
                            </div>
                            <div class="col-4">
                                <span>QO No.</span> <spna><t t-esc="o.qurbani_order_no"/></spna>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-4">
                                <span>Location</span> <spna><t t-esc="o.slaughter_location_id.name"/></spna>
                            </div>
                            <div class="col-4">
                                <span>Start Time</span> <spna><t t-esc="o.start_time" widget="float_time"/></spna>
                            </div>
                            <div class="col-4">
                                <span>End Time</span> <spna><t t-esc="o.end_time" widget="float_time"/></spna>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="qurbani_goat_slaughter_paperformat" model="report.paperformat">
        <field name="name">A4 - Qurbani Goat Slaughter</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">20</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">9</field>
    </record>

    <record id="qurbani_goat_slaughter_report" model="ir.actions.report">
        <field name="name">Qurbani Goat Slaughter</field>
        <field name="model">qurbani.goat.slaughter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_qurbani.qurbani_goat_slaughter_report_template</field>
        <field name="report_file">bn_qurbani.qurbani_goat_slaughter_report_template</field>
        <field name="binding_model_id" ref="bn_qurbani.model_qurbani_goat_slaughter"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="qurbani_goat_slaughter_paperformat"/>
    </record>

</odoo>
