<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="qurbani_order_sequence" model="ir.sequence">
            <field name="name">Qurbani Order</field>
            <field name="code">qurbani_order</field>
            <field name="prefix">QO/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    
        <record id="qurbani_order_line_sequence" model="ir.sequence">
            <field name="name">Qurbani Order Line</field>
            <field name="code">qurbani_order_line</field>
            <field name="prefix">QOL/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    
        <record id="qurbani_cow_distribution_sequence" model="ir.sequence">
            <field name="name">Qurbani Cow Distribution</field>
            <field name="code">qurbani_cow_distribution</field>
            <field name="prefix">QCD/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="qurbani_goat_distribution_sequence" model="ir.sequence">
            <field name="name">Qurbani Goat Distribution</field>
            <field name="code">qurbani_goat_distribution</field>
            <field name="prefix">QGD/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    
    </data>

</odoo>
