<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="bn_qurbani.QurbaniButton" t-inherit="bn_pos_custom_action.ActionScreen" t-inherit-mode="extension">
        <xpath expr="//main" position="inside">
            <button class="btn btn-secondary btn-lg flex-fill py-4 d-flex align-items-center justify-content-center" t-on-click="() => this.clickRecordQurbani()">
                <i class="fa fa-cutlery me-1 text-danager" role="img" aria-label="Qurbani" title="Qurbani" />
                Qurbani
            </button>
        </xpath>
    </t>

</templates>
