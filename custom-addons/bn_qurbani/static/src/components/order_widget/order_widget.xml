<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="bn_qurbani.OrderWidget" t-inherit="point_of_sale.OrderWidget" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('order-summary')]" position="inside">
            <div class="fs-6 text-muted subentry">
                Total Qty:
                <span t-esc="getTotalQty()"/>
            </div>
        </xpath>
    </t>

</templates>
