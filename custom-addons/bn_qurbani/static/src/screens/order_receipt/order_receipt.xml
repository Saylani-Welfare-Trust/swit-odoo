<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">

<t t-name="bn_qurbani.OrderReceipt"
   t-inherit="point_of_sale.OrderReceipt"
   t-inherit-mode="extension">

    <!-- SET VARIABLES (IMPORTANT) -->
    <xpath expr="//div[hasclass('pos-receipt')]" position="inside">
        <t t-set="company" t-value="props.data.headerData.company"/>
        <t t-set="order" t-value="props.data"/>
        <t t-set="partner" t-value="props.data.partner"/>
        <t t-set="lines" t-value="props.data.orderlines"/>
    </xpath>

    <!-- ===== HEADER ===== -->
    <xpath expr="//div[@name='custom-title']" position="replace">
        <div name="custom-title" class="col-6">
            <t t-if="order.is_qurbani">
                <h1>Qurbani Booking</h1>
            </t>
            <t t-else>
                <h1 t-if="order.receive_voucher">Receipt Voucher</h1>
                <h1 t-if="!order.receive_voucher">Donation Receipt</h1>
            </t>
        </div>
    </xpath>

    <!-- ===== ITEMS TABLE ===== -->
    <xpath expr="//table[@name='items-table']" position="replace">

        <!-- QURBANI MODE -->
        <t t-if="order.is_qurbani">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>City</th>
                        <th>Location</th>
                        <th>Day</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="lines" t-as="line">
                        <tr>
                            <td>
                                <t t-esc="line.productName or '-'"/>
                            </td>

                            <td>
                                <t t-esc="(line.productName && line.productName.toLowerCase().includes('yes') && line.qurbani_schedule_line) ? line.qurbani_schedule_line.city : '-'"/>
                            </td>

                            <td>
                                <t t-esc="(line.productName && line.productName.toLowerCase().includes('yes') && line.qurbani_schedule_line) ? line.qurbani_schedule_line.location : '-'"/>
                            </td>

                            <td>
                                <t t-esc="(line.qurbani_schedule_line && line.qurbani_schedule_line.slot) ? line.qurbani_schedule_line.slot.day : '-'"/>
                            </td>

                            <td>
                                <t t-esc="(line.qurbani_schedule_line && line.qurbani_schedule_line.slot && line.qurbani_schedule_line.slot.distribution) ? (line.qurbani_schedule_line.slot.distribution.start + ' - ' + line.qurbani_schedule_line.slot.distribution.end) : '-'"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>

        <!-- NORMAL MODE -->
        <t t-else>
            <table name="items-table" class="table table-bordered">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th t-if="!order.is_donation_in_kind">Rate</th>
                        <th t-if="!order.is_donation_in_kind">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="lines" t-as="line">
                        <tr>
                            <td><t t-esc="line.productName or '-'"/></td>
                            <td class="text-end"><t t-esc="line.qty or '-'"/></td>
                            <td t-if="!order.is_donation_in_kind" class="text-end">
                                <t t-esc="line.unitPrice || 0"/>
                            </td>
                            <td t-if="!order.is_donation_in_kind" class="text-end">
                                <t t-esc="line.price || 0"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>

    </xpath>

    <!-- ===== DETAILS ===== -->
    <xpath expr="//div[@name='custom-details']" position="replace">

        <!-- QURBANI -->
        <t t-if="order.is_qurbani">
            <div style="text-align:center; font-size:12px;">
                <t t-esc="order.halfnama or ''"/>
            </div>
        </t>

        <!-- NORMAL -->
        <t t-else>
            <div class="col-6">
                <div>
                    <strong>DN #:</strong>
                    <t t-set="city_code" t-value="order.branch_code or 'UNK'"/>
                    <t t-set="branch_code" t-value="company.name ? company.name.substring(0,3).toUpperCase() : 'UNK'"/>
                    <t t-set="year" t-value="order.date ? order.date.split('-')[0] : ''"/>
                    <t t-set="random_no" t-value="order.name ? order.name.slice(-4) : '0000'"/>

                    <span>
                        <t t-esc="city_code"/>-
                        <t t-esc="branch_code"/>-
                        <t t-esc="year"/>-
                        <t t-esc="random_no"/>
                    </span>
                </div>

                <div>
                    <strong>Donor Name:</strong>
                    <t t-esc="partner.name or '-'"/>
                </div>

                <div>
                    <strong>Products:</strong>
                    <t t-set="count" t-value="1"/>
                    <t t-foreach="lines" t-as="line">
                        <t t-esc="count"/>. <t t-esc="line.productName"/> - <t t-esc="line.qty"/>
                        <br/>
                        <t t-set="count" t-value="count + 1"/>
                    </t>
                </div>
            </div>

            <div class="col-6">
                <div>
                    <strong>Date Time:</strong>
                    <t t-esc="order.date"/>
                </div>

                <div>
                    <strong>Entered By:</strong>
                    <t t-esc="order.cashier"/>
                </div>
            </div>
        </t>

    </xpath>

</t>
</templates>