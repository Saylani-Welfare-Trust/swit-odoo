<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="generate_qurbani_distribution_view_form" model="ir.ui.view">
        <field name="name">generate.qurbani.distribution.view.form</field>
        <field name="model">generate.qurbani.distribution</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="inventory_product_name" invisible="1" />

                        <group name="generate_distribution_col_1">
                            <field name="day_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                            <field name="hijri_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                            <field name="distribution_location_id" domain="[('is_distribution_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                        </group>
                        <group name="generate_distribution_col_1">
                            <field name="inventory_product_id" domain="[('type', '=', 'product'), ('is_qurbani_inventory', '=', True), ('is_livestock', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Generate" type="object" name="action_generate_distribution" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="generate_qurbani_distribution_action" model="ir.actions.act_window">
        <field name="name">Generate Qurbani Distribution</field>
        <field name="res_model">generate.qurbani.distribution</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new generate qurbani distribution....
            </p>
        </field>
    </record>

    <menuitem
        id="generate_qurbani_distribution_menu"
        name="Qurbani Distribution"
        action="generate_qurbani_distribution_action"
        parent="bn_qurbani.qurbani_generate_menu"
        sequence="1"/>

</odoo>
