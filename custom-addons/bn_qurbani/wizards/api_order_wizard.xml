<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="api_donation_wizard_view_form" model="ir.ui.view">
        <field name="name">api.qurbani.wizard.view.form</field>
        <field name="model">api.qurbani.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="start_date"/>
                    </group>
                    <group>
                        <field name="end_date"/>
                    </group>
                </group>
                <footer>
                    <button name="action_fetch_qurbani" string="Fetch" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="api_donation_wizard_action" model="ir.actions.act_window">
        <field name="name">Fetch Web Orders</field>
        <field name="res_model">api.qurbani.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    

    <menuitem
        id="fetch_donation_menu"
        name="Fetch Web Orders"
        action="api_donation_wizard_action"
        parent="menu_qurbani_order"
        sequence="100"/>

</odoo>
