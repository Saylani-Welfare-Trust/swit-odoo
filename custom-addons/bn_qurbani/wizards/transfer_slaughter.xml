<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="transfer_slaughter_view_form" model="ir.ui.view">
        <field name="name">transfer.slaughter.view.form</field>
        <field name="model">transfer.slaughter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group name="transfer_slaughter_col_1">
                            <field name="qurbani_cow_slaughter_id" string="From" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_cow_slaughter_id" readonly="1" />
                            <field name="qurbani_cow_slaughter_line_id" invisible="1" />
                            
                            <field name="cow_slaughter_location_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_cow_slaughter_id" />
                            <field name="cow_product_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_cow_slaughter_line_id" />
                            <field name="cow_qurbani_order_no" invisible="not qurbani_cow_slaughter_line_id" />
                            <field name="cow_qurbani_order_line_no" invisible="not qurbani_cow_slaughter_line_id" />
                            <field name="cow_hissa_name" invisible="not qurbani_cow_slaughter_line_id" />
                            
                            <field name="qurbani_goat_slaughter_id" string="From" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_goat_slaughter_id" />
                            <field name="goat_slaughter_location_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_goat_slaughter_id" />
                            <field name="goat_product_id" options="{'no_create': True, 'no_edit': True, 'no_open': True}" invisible="not qurbani_goat_slaughter_id" />
                            <field name="goat_qurbani_order_no" invisible="not qurbani_goat_slaughter_id" />
                            <field name="goat_qurbani_order_line_no" invisible="not qurbani_goat_slaughter_id" />
                            <field name="goat_hissa_name" invisible="not qurbani_goat_slaughter_id" />
                        </group>
                        <group name="transfer_slaughter_col_2">
                            <field name="option" options="{'horizontal': True}" widget="radio" readonly="1" />

                            <field name="slaughter_location_id" string="Location" domain="[('is_slaughter_location', '=', True)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" />

                            <field name="start_time" widget="float_time" />
                            <field name="end_time" widget="float_time" />

                            <field name="actual_qurbani_cow_slaughter_id" string="To" domain="[('slot_full', '!=', 7), ('slaughter_location_id', '=', slaughter_location_id), ('start_time', '=', start_time), ('end_time', '=', end_time)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1" invisible="not qurbani_cow_slaughter_line_id or qurbani_goat_slaughter_id" />
                            <field name="actual_qurbani_cow_slaughter_id" string="To" domain="[('slot_full', '=', False), ('slaughter_location_id', '=', slaughter_location_id), ('start_time', '=', start_time), ('end_time', '=', end_time)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1" invisible="qurbani_cow_slaughter_line_id or qurbani_goat_slaughter_id" />
                            <field name="actual_qurbani_goat_slaughter_id" string="To" domain="[('slaughter_location_id', '=', slaughter_location_id.id), ('start_time', '=', start_time), ('end_time', '=', end_time)]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" required="1" invisible="not qurbani_goat_slaughter_id" />
                        </group>
                    </group>
                </sheet>
                 <footer>
                    <button string="Transfer" type="object" name="action_tranfer" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
