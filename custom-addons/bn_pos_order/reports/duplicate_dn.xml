<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="bn_pos_order.pos_donation_receipt_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="order">
                    <t t-call="web.external_layout">
                        <!-- Set Payment Method -->
                        <t t-set="payment_method" t-value="order.payment_ids and order.payment_ids[0].payment_method_id.name or ''"/>

                        <!-- PAGE WRAPPER -->
                        <div class="page" style="position:relative;">
                            <img t-if="order.env.company.dn_image" t-att-src="image_data_uri(order.env.company.dn_image)" style="max-height: 45px; max-width: 100%;" alt="Cover"/>

                            <!-- ===== STYLES ===== -->
                            <style>
                                body {
                                    font-family: Arial, sans-serif;
                                    font-size: 11px;
                                }

                                h1 {
                                    font-size: 14px;
                                    font-weight: bold;
                                    margin: 2px 0;
                                }

                                h4 {
                                    font-size: 12px;
                                    margin: 6px 0;
                                    font-weight: bold;
                                }

                                table {
                                    font-size: 11px;
                                    border-collapse: collapse;
                                }

                                th, td {
                                    padding: 3px 4px !important;
                                }

                                /* ✅ FIXED WATERMARK */
                                .watermark {
                                    position: absolute; /* was fixed */
                                    top: 120px;         /* adjust if needed */
                                    left: 50%;
                                    transform: translateX(-50%) rotate(-30deg);
                                    font-size: 80px;
                                    color: rgba(200, 200, 200, 0.15);
                                    font-weight: bold;
                                    white-space: nowrap;
                                    pointer-events: none;
                                    z-index: 0;
                                }
                            </style>

                            <!-- ===== WATERMARK ===== -->
                            <div class="watermark">DUPLICATE</div>

                            <!-- ===== HEADER ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <h1>Donation Receipt</h1>
                                </div>
                                <div class="col-6 text-end">
                                    <h1 class="text-transform" style="font-size: 12px;">
                                        SAYLANI WELFARE INTERNATIONAL TRUST
                                        <br/>
                                        <t t-if="order.user_id.branch_name">
                                            (<t t-esc="order.user_id.branch_name"/>)
                                        </t>
                                    </h1>
                                </div>
                            </div>

                            <hr style="margin:4px 0"/>

                            <!-- ===== BASIC INFO ===== -->
                            <div class="row mb-2">
                                <div style="display: flex; margin-bottom: 5px; font-size: 12px;">
                                    
                                </div>

                                <div class="col-6">
                                    <div>
                                        <strong>DN #:</strong>
                                        <t t-set="city_code" t-value="order.user_id.branch_code or 'UNK'"/>
                                        <t t-set="branch_code" t-value="order.company_id.name[:3].upper() or 'UNK'"/>
                                        <t t-set="current_year" t-value="order.date_order and order.date_order.year or ''"/>
                                        <t t-set="random_no" t-value="order.pos_reference and order.pos_reference[-4:] or '0000'"/>
                                        <t t-esc="city_code"/>-<t t-esc="branch_code"/>-<t t-esc="current_year"/>-<t t-esc="random_no"/>
                                    </div>
                                    <div><strong>Donor Name:</strong> <t t-esc="order.partner_id.name or '-'"/></div>
                                    <div><strong>CNIC No.:</strong> <t t-esc="order.partner_id.cnic_no or '-'"/></div>
                                    <div><strong>Payment Method:</strong> <t t-esc="payment_method"/></div>
                                    <div t-if="payment_method == 'Credit Card'"><strong>Reference No.:</strong> <t t-esc="order.name or ''"/></div>
                                    <div t-if="payment_method == 'Cheque'"><strong>Bank Name:</strong> <t t-esc="order.bank_name or ''"/></div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date &amp; Time:</strong>
                                        <t t-esc="order.create_date.strftime('%d-%m-%Y %H:%M') if order.create_date else '--'"/>
                                    </div>
                                    <div>
                                        <strong>Contact No.:</strong>
                                        <t t-esc="order.partner_id.mobile or '-'"/>
                                    </div>
                                    <div>
                                        <strong>Total Amount:</strong>
                                        <t t-esc="'{:,.2f}'.format(order.amount_total or 0)"/>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== ITEMS ===== -->
                            <h4>Direct Deposit Details</h4>

                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Quantity</th>
                                        <t t-if="payment_method != 'Donation In Kind'">
                                            <th>Rate</th>
                                            <th>Amount</th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="order.lines" t-as="line" t-key="line.id">
                                        <tr>
                                            <td><t t-esc="line.full_product_name"/></td>
                                            <td><t t-esc="int(line.qty)"/></td>
                                            <t t-if="payment_method != 'Donation In Kind'">
                                                <td>Rs <t t-esc="'{:,.2f}'.format(line.price_unit or 0)"/></td>
                                                <td>Rs <t t-esc="'{:,.2f}'.format(line.price_subtotal or 0)"/></td>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <hr style="margin:4px 0"/>

                            <!-- ===== TOTALS ===== -->
                            <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px;">
                                <div>Entered by: <strong><t t-esc="order.user_id.name"/></strong></div>
                                <div>Total Amount: <strong>Rs <t t-esc="'{:,.2f}'.format(order.amount_total or 0)"/></strong></div>
                            </div>

                            <hr style="margin:4px 0; border-top: solid 5px;"/>

                            <div class="row mb-2">
                                <div style="display: flex; margin-bottom: 5px; font-size: 12px;">
                                    
                                </div>

                                <div class="col-6">
                                    <div>
                                        <strong>DN #:</strong>
                                        <t t-set="city_code" t-value="order.user_id.branch_code or 'UNK'"/>
                                        <t t-set="branch_code" t-value="order.company_id.name[:3].upper() or 'UNK'"/>
                                        <t t-set="current_year" t-value="order.date_order and order.date_order.year or ''"/>
                                        <t t-set="random_no" t-value="order.pos_reference and order.pos_reference[-4:] or '0000'"/>
                                        <t t-esc="city_code"/>-<t t-esc="branch_code"/>-<t t-esc="current_year"/>-<t t-esc="random_no"/>
                                    </div>
                                    <div><strong>Donor Name:</strong> <t t-esc="order.partner_id.name or '-'"/></div>
                                    <div>
                                        <t t-set="count" t-value="1"/>
                                        <strong>Products:</strong>
                                        <t t-foreach="order.lines" t-as="l">
                                            <div><t t-esc="count"/>. <t t-esc="l.full_product_name"/> - <t t-esc="l.qty"/></div>
                                            <t t-set="count" t-value="count + 1"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date &amp; Time:</strong>
                                        <t t-esc="order.create_date.strftime('%d-%m-%Y %H:%M') if order.create_date else '--'"/>
                                    </div>
                                    <div><strong>Entered by: </strong> <t t-esc="order.user_id.name"/></div>
                                </div>
                            </div>

                            <div style="text-align: center; font-size: 12px;">
                                Powered by BytesNode
                            </div>

                        </div>

                    </t>
                </t>
            </t>
        </template>

        <record id="pos_donation_receipt_report" model="ir.actions.report">
            <field name="name">Duplicate Donation Receipt</field>
            <field name="model">pos.order</field>
            <field name="report_type">qweb-html</field>
            <field name="report_name">bn_pos_order.pos_donation_receipt_template</field>
            <field name="report_file">bn_pos_order.pos_donation_receipt_template</field>
            <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="bn_pos_order.paperformat_pos_donation_receipt_a5"/>
        </record>
    </data>
</odoo>
