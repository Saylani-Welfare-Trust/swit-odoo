<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Receipt Report Template -->
    <template id="report_advance_donation_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="receipt">
                <div class="page">
                    <!-- Header with Logo -->
                    <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #333; padding-bottom: 10px;">
                        <t if="receipt.company_id.logo">
                            <img t-att-src="'data:image/png;base64,%s' % receipt.company_id.logo" 
                                 style="max-height: 60px; margin-bottom: 5px;"/>
                        </t>
                        <h1 style="font-size: 24px; margin: 0;">DONATION RECEIPT</h1>
                        <p style="font-size: 12px; color: #666; margin: 5px 0;">Official Receipt for Donation Payment</p>
                    </div>
                    
                    <!-- Receipt Information -->
                    <table style="width: 100%; margin-bottom: 20px;">
                        <tr>
                            <td style="width: 50%;">
                                <p><strong>Receipt No:</strong> <span t-esc="receipt.name"/></p>
                                <p><strong>Date:</strong> <span t-esc="receipt.date"/></p>
                                <p><strong>Donor:</strong> <span t-esc="receipt.donor_id.name"/></p>
                            </td>
                            <td style="width: 50%; text-align: right;">
                                <p><strong>Payment Type:</strong> <span t-esc="dict(receipt.fields_get(allfields=['payment_type'])['payment_type']['selection'])[receipt.payment_type]"/></p>
                                <p><strong>Status:</strong> 
                                    <span t-if="receipt.state == 'paid'" style="color: green; font-weight: bold;">PAID</span>
                                    <span t-elif="receipt.state == 'draft'" style="color: orange; font-weight: bold;">DRAFT</span>
                                    <span t-elif="receipt.state == 'pending'" style="color: blue; font-weight: bold;">PENDING</span>
                                    <span t-elif="receipt.state == 'bounced'" style="color: red; font-weight: bold;">BOUNCED</span>
                                    <span t-else="" t-esc="receipt.state"/>
                                </p>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- Donation Details -->
                    <p><strong>Donation:</strong> <span t-esc="receipt.donation_id.name or 'N/A'"/></p>
                    <p><strong>Product:</strong> <span t-esc="receipt.product_id.display_name or 'N/A'"/></p>
                    
                    <!-- Cheque Details (if applicable) -->
                    <div t-if="receipt.payment_type == 'cheque'" style="background-color: #f9f9f9; padding: 10px; margin: 10px 0; border: 1px solid #ddd; border-radius: 4px;">
                        <p style="margin: 0;"><strong>Cheque Details:</strong></p>
                        <p style="margin: 5px 0;"><strong>Cheque Number:</strong> <span t-esc="receipt.cheque_number"/></p>
                        <p style="margin: 5px 0;"><strong>Cheque Date:</strong> <span t-esc="receipt.cheque_date"/></p>
                        <p t-if="receipt.bank_id" style="margin: 5px 0;"><strong>Bank:</strong> <span t-esc="receipt.bank_id.name"/></p>
                    </div>
                    
                    <!-- Bounced Reason (if applicable) -->
                    <div t-if="receipt.state == 'bounced' and receipt.bounced_reason" style="background-color: #ffebee; padding: 10px; margin: 10px 0; border: 1px solid #f44336; border-radius: 4px;">
                        <p style="margin: 0; color: #c62828;"><strong>Bounced Reason:</strong> <span t-esc="receipt.bounced_reason"/></p>
                    </div>
                    
                    <!-- Amount Table -->
                    <h4 style="margin-top: 20px; margin-bottom: 10px;">Payment Summary</h4>
                    <table class="table table-sm table-bordered" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background-color: #f0f0f0;">
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: left;">Description</th>
                                <th style="border: 1px solid #ddd; padding: 8px; text-align: right;">Amount (<span t-esc="receipt.currency_id.symbol"/>)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="border: 1px solid #ddd; padding: 8px;">Donation Amount</td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    <span t-esc="'{:,.2f}'.format(receipt.amount)"/>
                                </td>
                            </tr>
                            <tr style="font-weight: bold; background-color: #fafafa;">
                                <td style="border: 1px solid #ddd; padding: 8px;">Total Amount</td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    <span t-esc="'{:,.2f}'.format(receipt.amount)"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ddd; padding: 8px;">Used Amount</td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    <span t-esc="'{:,.2f}'.format(receipt.used_amount)"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #ddd; padding: 8px;">Remaining Amount</td>
                                <td style="border: 1px solid #ddd; padding: 8px; text-align: right;">
                                    <span t-esc="'{:,.2f}'.format(receipt.remaining_amount)"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <!-- Amount in Words (Optional) -->
                    <p style="margin-top: 10px;"><strong>Amount in Words:</strong> <span t-esc="receipt.amount_in_words or 'Not available'"/></p>
                    
                    <!-- Footer -->
                    <div style="margin-top: 40px; border-top: 2px solid #333; padding-top: 20px;">
                        <table style="width: 100%;">
                            <tr>
                                <td style="width: 50%;">
                                    <p><strong>Generated Date:</strong> <span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/></p>
                                    <p><strong>Generated By:</strong> <span t-esc="receipt.create_uid.name or ''"/></p>
                                </td>
                                <td style="width: 50%; text-align: right;">
                                    <p><strong>Authorized Signature:</strong> ___________________________</p>
                                    <p style="font-size: 10px; color: #666; margin-top: 10px;">
                                        <em>Authorized Officer</em>
                                    </p>
                                </td>
                            </tr>
                        </table>
                        <p style="font-size: 10px; color: #666; text-align: center; margin-top: 20px; border-top: 1px solid #eee; padding-top: 10px;">
                            <em>This is a computer-generated receipt. No physical signature required.</em><br/>
                            <em>Thank you for your generous donation!</em>
                        </p>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <!-- Report Action -->
    <record id="action_report_advance_donation_receipt" model="ir.actions.report">
        <field name="name">Donation Receipt</field>
        <field name="model">advance.donation.receipt</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_advance_donation.report_advance_donation_receipt</field>
        <field name="report_file">bn_advance_donation.report_advance_donation_receipt</field>
        <field name="binding_model_id" ref="model_advance_donation_receipt"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Donation Receipt - %s' % (object.name)</field>
    </record>
</odoo>