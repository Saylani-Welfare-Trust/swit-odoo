<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <!-- ===================== -->
        <!-- Donation Receipt -->
        <!-- ===================== -->
        <template id="report_advance_donation_receipt">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="receipt">
                    <t t-call="web.external_layout">
                        <!-- PAGE WRAPPER -->
                        <div class="page" style="position:relative;">

                            <!-- ===== STYLES ===== -->
                            <style>
                                body {
                                    font-family: Arial, sans-serif;
                                    font-size: 11px;
                                }

                                h1 {
                                    font-size: 14px;
                                    font-weight: bold;
                                    margin: 2px 0;
                                }

                                h4 {
                                    font-size: 12px;
                                    margin: 6px 0;
                                    font-weight: bold;
                                }

                                table {
                                    font-size: 11px;
                                    border-collapse: collapse;
                                }

                                th, td {
                                    padding: 3px 4px !important;
                                }

                                .watermark {
                                    position: absolute;
                                    top: 170px;
                                    left: 50%;
                                    transform: translateX(-50%) rotate(-30deg);
                                    font-size: 80px;
                                    color: rgba(200, 200, 200, 0.15);
                                    font-weight: bold;
                                    white-space: nowrap;
                                    pointer-events: none;
                                    z-index: 0;
                                }

                                .text-end {
                                    text-align: right !important;
                                }

                                .text-center {
                                    text-align: center !important;
                                }
                            </style>

                            <!-- ===== WATERMARK ===== -->
                            <div t-if="receipt.state == 'draft'" class="watermark">Draft</div>
                            <div t-if="receipt.state == 'pending'" class="watermark">Pending</div>
                            <div t-if="receipt.state == 'bounced'" class="watermark">Bounced</div>

                            <!-- ===== HEADER ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <h1>Donation Receipt</h1>
                                </div>
                                <div class="col-6 text-end">
                                    <h1>
                                        <t t-esc="receipt.env.company.name or 'Saylani Welfare International Trust'"/>
                                    </h1>
                                </div>
                            </div>

                            <hr style="margin:4px 0"/>

                            <!-- ===== BASIC INFO ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <div><strong>Receipt #:</strong> <t t-esc="receipt.name or '--'"/></div>
                                    <div name="donor_name"><strong>Donor Name:</strong> <t t-esc="receipt.donor_id.name or '-'"/></div>
                                    <div><strong>Donation:</strong> <t t-esc="receipt.donation_id.name or '-'"/></div>
                                    <div><strong>Product:</strong> <t t-esc="receipt.product_id.display_name or '-'"/></div>
                                    <div><strong>Payment Type:</strong> <t t-esc="dict(receipt.fields_get(allfields=['payment_type'])['payment_type']['selection'])[receipt.payment_type]"/></div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date:</strong>
                                        <t t-esc="receipt.date.strftime('%d-%m-%Y') if receipt.date else '--'"/>
                                    </div>
                                    <div>
                                        <strong>Status:</strong>
                                        <t t-if="receipt.state == 'draft'">Draft</t>
                                        <t t-elif="receipt.state == 'paid'" style="color: green; font-weight: bold;">Paid</t>
                                        <t t-elif="receipt.state == 'pending'" style="color: orange; font-weight: bold;">Pending</t>
                                        <t t-elif="receipt.state == 'bounced'" style="color: red; font-weight: bold;">Bounced</t>
                                        <t t-else="" t-esc="receipt.state"/>
                                    </div>
                                    <div t-if="receipt.payment_type == 'cheque'">
                                        <strong>Cheque #:</strong> <t t-esc="receipt.cheque_number or '-'"/>
                                    </div>
                                    <div t-if="receipt.payment_type == 'cheque'">
                                        <strong>Cheque Date:</strong> 
                                        <t t-esc="receipt.cheque_date.strftime('%d-%m-%Y') if receipt.cheque_date else '--'"/>
                                    </div>
                                    <div t-if="receipt.payment_type == 'cheque' and receipt.bank_id">
                                        <strong>Bank:</strong> <t t-esc="receipt.bank_id.name"/>
                                    </div>
                                    <div t-if="receipt.state == 'bounced' and receipt.bounced_reason">
                                        <strong>Bounced Reason:</strong> <t t-esc="receipt.bounced_reason"/>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== AMOUNT TABLE ===== -->
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Description</th>
                                        <th class="text-end">Amount (Rs)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Donation Amount</td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(receipt.amount or 0)"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Amount</strong></td>
                                        <td class="text-end"><strong><t t-esc="'{:,.2f}'.format(receipt.amount or 0)"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td>Used Amount</td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(receipt.used_amount or 0)"/></td>
                                    </tr>
                                    <tr>
                                        <td>Remaining Amount</td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(receipt.remaining_amount or 0)"/></td>
                                    </tr>
                                </tbody>
                            </table>

                            <hr style="margin:4px 0"/>

                            <!-- ===== TOTALS ===== -->
                            <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px;">
                                <div>Generated by: <strong><t t-esc="receipt.create_uid.name or receipt.user_id.name or ''"/></strong></div>
                                <div>Total Amount: <strong>Rs <t t-esc="'{:,.2f}'.format(receipt.amount or 0)"/></strong></div>
                            </div>

                            <hr style="margin:4px 0; border-top: solid 5px;"/>

                            <!-- ===== FOOTER DETAILS ===== -->
                            <div class="row mb-2">
                                <div class="col-6">
                                    <div><strong>Receipt #:</strong> <t t-esc="receipt.name or '--'"/></div>
                                    <div><strong>Donor Name:</strong> <t t-esc="receipt.donor_id.name or '-'"/></div>
                                    <div>
                                        <t t-if="receipt.donation_id">
                                            <strong>Donation:</strong> <t t-esc="receipt.donation_id.name"/>
                                        </t>
                                    </div>
                                    <div t-if="receipt.product_id">
                                        <strong>Product:</strong> <t t-esc="receipt.product_id.display_name"/>
                                    </div>
                                    <div t-if="receipt.payment_type == 'cheque'">
                                        <strong>Cheque #:</strong> <t t-esc="receipt.cheque_number or '-'"/>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <strong>Date:</strong>
                                        <t t-esc="receipt.date.strftime('%d-%m-%Y') if receipt.date else '--'"/>
                                    </div>
                                    <div><strong>Generated by: </strong> <t t-esc="receipt.create_uid.name or receipt.user_id.name or ''"/></div>
                                    <div>
                                        <strong>Status:</strong>
                                        <t t-if="receipt.state == 'draft'">Draft</t>
                                        <t t-elif="receipt.state == 'paid'" style="color: green; font-weight: bold;">✓ Paid</t>
                                        <t t-elif="receipt.state == 'pending'" style="color: orange; font-weight: bold;">⏳ Pending</t>
                                        <t t-elif="receipt.state == 'bounced'" style="color: red; font-weight: bold;">✗ Bounced</t>
                                    </div>
                                    <div t-if="receipt.state == 'paid'">
                                        <strong>Payment Confirmed:</strong> 
                                        <t t-esc="receipt.write_date.strftime('%d-%m-%Y %H:%M') if receipt.write_date else '--'"/>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== SIGNATURE ===== -->
                            <div style="margin-top: 15px; padding-top: 10px; border-top: 1px solid #ddd;">
                                <div style="display: flex; justify-content: space-between;">
                                    <div>
                                        <span style="font-size: 10px;">Receiver Signature</span>
                                        <br/>
                                        <span style="font-size: 10px;">_________________________</span>
                                    </div>
                                    <div style="text-align: right;">
                                        <span style="font-size: 10px;">Authorized Signature</span>
                                        <br/>
                                        <span style="font-size: 10px;">_________________________</span>
                                    </div>
                                </div>
                            </div>

                            <!-- ===== FOOTER ===== -->
                            <div style="text-align: center; font-size: 10px; margin-top: 10px; color: #666;">
                                <t t-esc="receipt.env.company.name or 'Saylani Welfare International Trust'"/>
                                <br/>
                                <span style="font-size: 8px;">This is a computer-generated receipt. No physical signature required.</span>
                                <br/>
                                <span style="font-size: 8px;">Thank you for your generous donation!</span>
                                <br/>
                                <span style="font-size: 8px;">Powered by BytesNode</span>
                            </div>

                        </div>
                    </t>
                </t>
            </t>
        </template>

        <!-- ===================== -->
        <!-- Paper Format -->
        <!-- ===================== -->
        <record id="report_advance_donation_receipt_paperformat" model="report.paperformat">
            <field name="name">A5 - Donation Receipt</field>
            <field name="format">A5</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">84.67</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">4</field>
            <field name="margin_right">4</field>
            <field name="header_spacing">0</field>
            <field name="dpi">90</field>
        </record>

        <!-- ===================== -->
        <!-- Report Action -->
        <!-- ===================== -->
        <record id="action_report_advance_donation_receipt" model="ir.actions.report">
            <field name="name">Donation Receipt</field>
            <field name="model">advance.donation.receipt</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bn_advance_donation.report_advance_donation_receipt</field>
            <field name="report_file">bn_advance_donation.report_advance_donation_receipt</field>
            <field name="binding_model_id" ref="model_advance_donation_receipt"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Donation Receipt - %s' % (object.name)</field>
            <field name="paperformat_id" ref="report_advance_donation_receipt_paperformat"/>
        </record>

    </data>
</odoo>