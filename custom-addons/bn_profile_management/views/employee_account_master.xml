<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="employee_account_master_view_tree" model="ir.ui.view">
        <field name="name">employee.account.master.view.tree</field>
        <field name="model">employee.account.master</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="advance_account_code" />
                <field name="petty_cash_account_code" />
            </tree>
        </field>
    </record>

    <record id="employee_account_master_action" model="ir.actions.act_window">
        <field name="name">Employee Accounts</field>
        <field name="res_model">employee.account.master</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's create a new employee account master....
            </p>
        </field>
    </record>

    <menuitem
        id="employee_account_master_menu"
        name="Employee Accounts"
        action="employee_account_master_action"
        parent="bn_master_setup.master_setup_menu"
        sequence="4"/>

</odoo>
