<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fetch_log_view_tree" model="ir.ui.view">
        <field name="name">fetch.log.view.tree</field>
        <field name="model">fetch.log</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="name" />
                <field name="status" />
                <field name="reason" />
                <field name="create_date" />
            </tree>
        </field>
    </record>

    <record id="fetch_log_action" model="ir.actions.act_window">
        <field name="name">Fetch Logs</field>
        <field name="res_model">fetch.log</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for Fetch Logs....
            </p>
        </field>
    </record>

    <menuitem
        id="fetch_log_menu"
        name="Fetch Logs"
        action="fetch_log_action"
        parent="bn_import_donation.api_donation_menu"
        sequence="3"/>

</odoo>
