<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fetch_log_view_tree" model="ir.ui.view">
        <field name="name">fetch.log.view.tree</field>
        <field name="model">fetch.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="status" />
                <field name="reason" />
                <field name="create_date" />
            </tree>
        </field>
    </record>

    <record id="fetch_all_log_action" model="ir.actions.act_window">
        <field name="name">Fetch All Logs</field>
        <field name="res_model">fetch.log</field>
        <field name="view_mode">tree</field>
        <field name="context">{
            'create': 0,
            'edit': 0,
            'delete': 0,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for Fetch Logs....
            </p>
        </field>
    </record>
    
    <record id="fetch_error_log_action" model="ir.actions.act_window">
        <field name="name">Fetch Error Logs</field>
        <field name="res_model">fetch.log</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('status', '=', 'Error')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for Fetch Logs....
            </p>
        </field>
    </record>

    <menuitem
        id="fetch_log_menu"
        name="Fetch Logs"
        parent="bn_import_donation.api_donation_menu"
        sequence="3"/>

    <menuitem
        id="fetch_all_log_menu"
        name="Fetch All Logs"
        action="fetch_all_log_action"
        parent="fetch_log_menu"
        sequence="0"/>

    <menuitem
        id="fetch_error_log_menu"
        name="Fetch Error Logs"
        action="fetch_error_log_action"
        parent="fetch_log_menu"
        sequence="1"/>

</odoo>
