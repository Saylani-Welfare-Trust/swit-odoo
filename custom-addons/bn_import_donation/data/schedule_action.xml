<?xml version="1.0" encoding='UTF-8'?>
<odoo>
    <data noupdate="1">

        <!--        The schedular action for Recurring  Entries-->
        <record id="sync_fetch_donation_cron" model="ir.cron">
            <field name="name">Fetch Donation Data</field>
            <field name="model_id" ref="model_api_donation_wizard"/>
            <field name="state">code</field>
            <field name="code">model.action_fetch_donation()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>
