<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="bn_donation_box.donation_box_receipt_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <!-- PAGE WRAPPER -->
                    <div class="page" style="position:relative;">
                        <!-- ===== STYLES ===== -->
                        <style>
                            body {
                                font-family: Arial, sans-serif;
                                font-size: 11px;
                            }

                            h1 {
                                font-size: 14px;
                                font-weight: bold;
                                margin: 2px 0;
                            }

                            h4 {
                                font-size: 12px;
                                margin: 6px 0;
                                font-weight: bold;
                            }

                            table {
                                font-size: 11px;
                                border-collapse: collapse;
                            }

                            th, td {
                                padding: 3px 4px !important;
                            }

                            /* ✅ FIXED WATERMARK */
                            .watermark {
                                position: absolute; /* was fixed */
                                top: 420px;         /* adjust if needed */
                                left: 50%;
                                transform: translateX(-50%) rotate(-30deg);
                                font-size: 80px;
                                color: rgba(200, 200, 200, 0.15);
                                font-weight: bold;
                                white-space: nowrap;
                                pointer-events: none;
                                z-index: 0;
                            }
                        </style>

                        <img t-if="o.env.company.dn_image"
                            t-att-src="image_data_uri(o.env.company.dn_image)"
                            style="height: 100%; width: 100%;"/>

                        <!-- ===== WATERMARK ===== -->
                        <div class="watermark">Certificate</div>

                        <!-- ===== HEADER ===== -->
                        <div class="row mb-2">
                            <div class="col-6">
                                <h1>Donation Box</h1>
                            </div>
                            <div class="col-6 text-end">
                                <h1>
                                    Saylani Welfare International Trust
                                    <t t-if="o.user_id.employee_id.analytic_account_id">
                                        <br/>
                                        (<t t-esc="o.rider_id.analytic_account_id.name"/>)
                                    </t>
                                </h1>
                                <p class="text-muted mb-2">
                                    This certificate acknowledges the collection from donation box
                                </p>
                            </div>
                        </div>

                        <hr style="margin:4px 0"/>

                        <!-- ===== BASIC INFO ===== -->
                        <div class="row mb-2">
                            <div class="col-6">
                                <div><strong>DB #:</strong> <t t-esc="o.name or '--'"/></div>
                                <div><strong>Box No.:</strong> <t t-esc="o.lot_id.name or '-'"/></div>
                                <div><strong>Issued On:</strong> <t t-esc="o.issued_on.strftime('%d-%m-%Y') or '-'"/></div>
                                <div><strong>Returned On:</strong> <t t-esc="o.returned_on.strftime('%d-%m-%Y') or '-'"/></div>
                            </div>
                            <div class="col-6">
                                <div>
                                    <strong>Certificate Date::</strong>
                                    <t t-import="datetime"/>
                                    <t t-esc="datetime.datetime.now().strftime('%d-%m-%Y')"/>
                                </div>
                                <div>
                                    <strong>Installer Name:</strong>
                                    <t t-esc="o.installer_id.name or '-'"/>
                                </div>
                                <div>
                                    <strong>Installation Category:</strong>
                                    <t t-esc="o.installation_category_id.name or '-'"/>
                                </div>
                                <div>
                                    <strong>Installation Date:</strong>
                                    <t t-esc="o.installation_date.strftime('%d-%m-%Y') or '-'"/>
                                </div>
                            </div>
                        </div>

                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th>Category</th>
                                    <th>Registration</th>
                                    <th class="text-yend">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <t t-esc="o.product_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="o.donation_box_request_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="'{:,}'.format(int(o.donation_amount) or 0)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <hr style="margin:4px 0"/>

                        <!-- ===== TOTALS ===== -->
                        <div style="display:flex; justify-content:space-between; margin-top:10px; font-size:10px;">
                            <div>Entered by: <strong><t t-esc="o.rider_id.name"/></strong></div>
                            <div>Total Amount: <strong>Rs <t t-esc="'{:,}'.format(int(o.donation_amount) or 0)"/></strong></div>
                        </div>

                        <!-- Footer -->
                        <div class="mt-4">
                            <div class="border-top border-2 pt-3">
                                <!-- Certificate Note -->
                                <p class="text-center text-muted fst-italic mb-2" style="font-size: 12px;">
                                    This certificate is digitally generated and serves as an official acknowledgment of the donation box collection.
                                </p>

                                <!-- Signature Section -->
                                <div class="mt-3">
                                    <div class="d-flex justify-content-start">
                                        <div class="signature-line">
                                            <p class="mb-0 text-muted mt-1" style="font-size: 12px;">
                                                Authorized Signature
                                            </p>
                                        </div>
                                    </div>

                                    <!-- Powered By Section -->
                                    <div class="text-center mt-3">
                                        <p class="mb-1 text-muted" style="font-size: 12px;">
                                            Powered by <strong>BytesNode</strong>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </t>
            </t>
        </t>
    </template>

    <record id="report_donation_box_paperformat" model="report.paperformat">
        <field name="name">A5 - Donation Box Receipt</field>
        <field name="format">A5</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="donation_box_receipt_report_action" model="ir.actions.report">
        <field name="name">Donation Box Receipt</field>
        <field name="model">key.issuance</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bn_donation_box.donation_box_receipt_template</field>
        <field name="report_file">bn_donation_box.donation_box_receipt_template</field>
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Donation Box Receipt - %s' % (object.lot_id.name)</field>
        <field name="paperformat_id" ref="bn_donation_box.report_donation_box_paperformat"/>
    </record>

</odoo>
