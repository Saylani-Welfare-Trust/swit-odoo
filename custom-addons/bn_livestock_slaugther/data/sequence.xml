<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="distribution_center_sequence" model="ir.sequence">
            <field name="name">Distribution Center</field>
            <field name="code">distribution_center</field>
            <field name="prefix">DC/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    
        <record id="livestock_slaughter_sequence" model="ir.sequence">
            <field name="name">Livestock Slaughter</field>
            <field name="code">livestock_slaugther</field>
            <field name="prefix">LS/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    
        <record id="livestock_cutting_sequence" model="ir.sequence">
