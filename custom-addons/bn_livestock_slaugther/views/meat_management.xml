<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="meat_management_view_tree" model="ir.ui.view">
        <field name="name">meat.management.view.tree</field>
        <field name="model">meat.management</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="total_raw_meat_qty" />
                <field name="total_livestock_qty" />
                <field name="excess_livestock_qty" />
            </tree>
        </field>
    </record>

    <record id="livestock_meat_management_view_form" model="ir.ui.view">
        <field name="name">meat.management.view.form</field>
        <field name="model">meat.management</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="month"/>
                        <h1><field name="month" class="oe_inline" required="1" /></h1>
                    </div>

                    <group>
                        <group name="meat_management_col_1">
                            <field name="total_raw_meat_qty" />
                            <field name="excess_livestock_qty" />
                        </group>
                        <group name="meat_management_col_2">
                            <field name="total_livestock_qty" />
                        </group>
                    </group>

                    <notebook>
                        <page name="kitchen_management" string="Kitchen Management">
                            <field name="kitchen_meat_management_line_ids">
                                <tree editable="bottom">
                                    <field name="date" />
                                    <field name="quantity" />
                                </tree>
                            </field>
                        </page>
                        <page name="madaris_management" string="Madaris Management">
                            <field name="madaris_meat_management_line_ids">
                                <tree editable="bottom">
                                    <field name="date" />
                                    <field name="quantity" />
                                </tree>
                            </field>
                        </page>
                        <page name="medical_management" string="Medical Management">
                            <field name="medical_meat_management_line_ids">
                                <tree editable="bottom">
                                    <field name="date" />
                                    <field name="quantity" />
                                </tree>
                            </field>
                        </page>
                        <page name="livestock_management" string="Livestock Management">
                            <field name="livestock_meat_management_line_ids">
                                <tree editable="bottom">
                                    <field name="date" />
                                    <field name="product_id" />
                                    <field name="location_id" />
                                    <field name="quantity" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="meat_management_action" model="ir.actions.act_window">
        <field name="name">Meat Management</field>
        <field name="res_model">meat.management</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Let's add a new meat management...
            </p>
        </field>
    </record>

    <menuitem
        id="meat_management_menu"
        name="Meat Management"
        action="meat_management_action"
        parent="bn_livestock_slaugther.livestock_menu"
        sequence="6"/>

</odoo>
