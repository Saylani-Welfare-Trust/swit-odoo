<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit account.payment form view to add cheque_date field -->
    <record id="view_account_payment_form_cheque_date" model="ir.ui.view">
        <field name="name">account.payment.form.cheque.date</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date']" position="after">
                <field name="cheque_date" readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit account.payment.register form view to add cheque_date field -->
    <record id="view_account_payment_register_form_cheque_date" model="ir.ui.view">
        <field name="name">account.payment.register.form.cheque.date</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_date']" position="after">
                <field name="cheque_date"/>
            </xpath>
        </field>
    </record>
</odoo>
