<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Purchase Order Line Tree View - Show Livestock Fields -->
    <record id="purchase_order_line_tree_view_inherit" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.inherit.livestock</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <field name="price_unit" position="after">
                <field name="x_base_price" optional="hide" readonly="1"/>
                <field name="to_kg_multiplier" optional="hide" readonly="1"/>
            </field>
        </field>
    </record>

    <!-- Purchase Order Form View - Show Livestock Fields in Order Lines -->
    <record id="purchase_order_form_view_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.livestock</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="after">
                <field name="x_base_price" optional="hide" readonly="1"/>
                <field name="to_kg_multiplier" optional="hide" readonly="1"/>
                <field name="main_attribute_id" column_invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
