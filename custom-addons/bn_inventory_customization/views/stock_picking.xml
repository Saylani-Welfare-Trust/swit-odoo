<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add bill_amount field to stock picking form -->
    <record id="view_picking_form_inherit_bill_amount" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.bill.amount</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Place bill_amount right after origin -->
            <field name="origin" position="after">
                <field name="bill_amount"/>
            </field>
        </field>
    </record>

    <!-- Add Receive by Weight button to stock picking form -->
    <record id="stock_view_picking_form_inherit_bn_inventory_customization" model="ir.ui.view">
        <field name="name">stock.view.picking.form.inherit.bn.inventory.customization</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="show_receive_by_weight" invisible="1"/>
                <button name="open_receive_by_weight_wizard"
                        type="object"
                        string="Receive by Weight"
                        class="btn-primary"
                        invisible="show_receive_by_weight != True"/>
            </xpath>
        </field>
    </record>

</odoo>
