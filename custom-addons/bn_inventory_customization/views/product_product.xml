<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Show check_stock and livestock fields on product variant form -->
    <record id="product_product_normal_form_view_inherit_bn_inventory_customization" model="ir.ui.view">
        <field name="name">product.product.normal.form.view.inherit.bn.inventory.customization</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <!-- Add check_stock checkbox in options section -->
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-flex">
                    <field name="check_stock" on_change="1" field_id="check_stock" readonly="0"/>
                    <label for="check_stock"/>
                </span>
            </xpath>
            
            <!-- Add Livestock Configuration section in General Information tab -->
            <xpath expr="//group[@name='group_general']" position="after">
                <group string="Livestock Configuration" name="livestock_config" invisible="check_stock == False">
                    <group>
                        <field name="livestock_variant" options="{'no_create': True, 'no_open': True}"/>
                        <field name="purchase_product" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                    <group>
                        <field name="main_attribute_id" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
