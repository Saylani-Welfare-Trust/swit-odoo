<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="medical_equipment_view_tree" model="ir.ui.view">
        <field name="name">medical.equipment.view.tree</field>
        <field name="model">medical.equipment</field>
        <field name="arch" type="xml">
            <tree default_order="create_date desc">
                <field name="name"/>
                <field name="donee_id"/>
                <field name="state"  widget="badge" decoration-warning="state == 'draft'" decoration-info="state in ['payment_received', 'payment_return', 'validate']" decoration-success="state == 'return'" />
            </tree>
        </field>
    </record>

    <record id="medical_equipment_view_form" model="ir.ui.view">
        <field name="name">medical.equipment.view.form</field>
        <field name="model">medical.equipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" invisible="1"/>
                    <field name="is_donee_register" invisible="1" />
                    <!-- <field name="case_type" invisible="1" /> -->
                    <field name="Portal_acknowledgment" invisible="1" />
                    <button string="Complete" name="action_complete" type="object" class="oe_highlight" invisible="state != 'draft'" />

                    
                    <button string="Register Donee" name="action_register_donee" type="object" class="oe_highlight" invisible="is_donee_register or not donee_id" />
                    
                    <button string="Approval (1)" name="action_approval" type="object" class="oe_highlight" groups="bn_medical_equipment.medical_equipment_ceo_approval_group" invisible=" not approval_button_check"/>
                    <button string="Approval (2)" name="action_approval" type="object" class="oe_highlight" groups="bn_medical_equipment.medical_equipment_cfo_approval_group" invisible="case_type == False or state != 'ceo_approval'" />
                    
                    <button string="Sync to Portal" name="action_send_for_inquiry" type="object" invisible="case_type != 'below_50_percent' or state != 'completed'" />
                    <button string="Portal Acknowledgment " name="action_check_portal_status" type="object" invisible=" state !='send_for_inquiry'" />
                    
                    <button string="Validate" name="action_validate" type="object" class="oe_highlight" invisible="state != 'sd_received'" />
                    <button string="Recovery" name="action_recovery" type="object" class="oe_highlight" invisible="state != 'validate'" />
                    <button string="Return" name="action_return" type="object" invisible="state != 'validate'" />
                    <button string="Refund" name="action_refund" type="object" invisible="state != 'return'" />
                    <button string="Donate" name="action_donate" type="object" invisible="state != 'return'" />

                    <field name="state" widget="statusbar" statusbar_visible="draft, ceo_approval, cfo_approval, approved, sd_received, validate, return, payment_return, send_for_inquiry, inquiry" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="picking_id" invisible="1"/>
                        <field name="return_picking_id" invisible="1"/>

                        <button name="action_show_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id">
                            <field name="picking_id" widget="statinfo"/>
                        </button>
                        <button name="action_show_return_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not return_picking_id">
                            <field name="return_picking_id" widget="statinfo"/>
                        </button>
                        <button name="action_show_recovery_picking" type="object" class="oe_stat_button" icon="fa-truck" invisible="not recovery_picking_id">
                            <field name="recovery_picking_id" widget="statinfo"/>
                        </button>
                        <button name="action_show_sd_slip" type="object" class="oe_stat_button" icon="fa-money" invisible="not sd_slip_id">
                            <field name="sd_slip_id" widget="statinfo"/>
                        </button>
                        <button name="action_show_move" type="object" class="oe_stat_button" icon="fa-money" invisible="not move_id">
                            <field name="move_id" string="Journal Entry" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name" string="Request No." />
                        <h1><field name="name" readonly="1" /></h1>
                    </div>

                    <group>
                        <group name="medical_equipment_col_1">
                            <field name="portal_application_id" invisible="1"/>
                            <field name="is_actual_deposit_editable" invisible="1"/> 
                            <field name="approval_button_check" invisible="1"/>
                            <field name="employee_category_id" invisible="1" />
                            <field name="actual_deposit_percentage" readonly = "not is_actual_deposit_editable"/>
                            <field name="case_type" readonly="1" string="Auto-Determined Case Type" invisible="1"/>
                            <field name="cnic_no" readonly="state != 'draft'" required="1" />
                            <field name="street" string="Address" readonly="state != 'draft'" required="1"  force_save="1"/>
                            <field name="city" required="1" readonly="state != 'draft'" />
                            <field name="general_remarks" string="General Remarks" readonly="state != 'draft'" />
                            <field name="remarks_approval1" 
                                required="case_type in ['50_percent', 'below_50_percent'] and state == 'ceo_approval'"
                                readonly="state not in ['inquiry','completed']"/>

                            <field name="remarks_approval2" 
                                required="case_type in ['50_percent', 'below_50_percent'] and state == 'cfo_approval'"
                                readonly="state != 'ceo_approval'"/>

                            <field name="employee_id" string="Inquiry Officer" domain="[('category_ids', 'in', [employee_category_id])]" options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="state != 'draft'" />
                            <field name="picking_id" invisible="1" readonly="1"/>
                           
                            <field name="application_location_link" readonly="state != 'draft'" required="0" />
                            <field name="total_amount" string="Loan request Amount" readonly="1"/>

                            <!-- <field name="loan_request_amount" readonly="state != 'draft'" /> -->
                            <field name="last_sync_date" readonly="1" />
                        </group>
                        <group name="medical_equipment_col_2">
                            <label for="mobile"/>
                            <div style="display: flex;">
                                <field options="{'no_create': True, 'no_edit': True, 'no_open': True}" readonly="state != 'draft'" style="width: 30% !important;" name="country_code_id" nolabel="1" required="1" /> 
                                <field style="width: 70% !important;" name="mobile" readonly="state != 'draft'" nolabel="1" required="1" />
                            </div>
                            <field name="gender" required="1" readonly="state != 'draft'" />
                            <field name="date_of_birth" required="1" readonly="state != 'draft'" />
                            <field name="age" readonly="1" />
                            <field name="donee_id" string="Donee" readonly="state != 'draft'" options="{'no_edit': True, 'no_open': True}" domain="[('category_id.name', '=', 'Donee'), ('category_id.name', '=', 'Medical'), ('state', '=', 'register')]" context="{'default_category_id': [(6, 0, [3, 4, 8])], 'default_country_code_id': country_code_id, 'default_city': city, 'default_street': street, 'default_cnic_no': cnic_no, 'default_mobile': mobile, 'default_date_of_birth': date_of_birth, 'default_gender': gender}" required="1" />
                            <field name="currency_id" invisible="1"/>

                            <field name="portal_review_notes" readonly="1" />
                            <field name="inquiry_media" widget="html" readonly="1"/>

                        </group>
                    </group>

                    <group string="Welfare Portal Information" invisible="case_type != 'below_50_percent'">
                        <field name="welfare_portal_id" readonly="1" />
                        <field name="Portal_acknowledgment" readonly="1" />
                    </group>

                    <notebook>
                        <page string="Items">
                            <field name="medical_equipment_line_ids">
                                <tree editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>

                                    <field name="medical_equipment_category_id"
                                        string="Master Product"
                                        width="200"
                                        options="{'no_quick_create': True, 'no_create_edit': True}"/>

                                    <field name="product_id"
                                        width="200"
                                        options="{'no_quick_create': True, 'no_create_edit': True}"
                                        readonly="1"/>
                                    <field name="lot_ids"
                                        options="{'no_create': True, 'no_edit': True, 'no_open': True}" 
                                        string="Product No./Lot"
                                        widget="many2many_tags"
                                        domain="[('product_id', '=', product_id), ('lot_consume', '=', False)]"
                                        width="100"
                                        required="1"
                                    />

                                    <field name="quantity" width="100"/>
                                    <field name="base_security_deposit" width="150" readonly="1"/>
                                    <field name="actual_deposit_percentage" width="150" readonly="1"/>
                                    <field name="security_deposit" width="150" readonly="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="total_amount" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="medical_equipment_action" model="ir.actions.act_window">
        <field name="name">Medical Equipment</field>
        <field name="res_model">medical.equipment</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for a new record...
            </p>
        </field>
    </record>

    <record id="donaiton_box_operation_action" model="ir.actions.act_window">
        <field name="name">Medical Equipment Operation</field>
        <field name="res_model">stock.picking.type</field>
        <field name="view_mode">kanban</field>
        <field name="domain">[('name', '=', 'Medical Equipment')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Waiting for an operation to occur...
            </p>
        </field>
    </record>

    <menuitem
        id="medical_equipment_menu"
        web_icon="bn_medical_equipment,static/description/icon.png"
        groups="bn_medical_equipment.medical_equipment_menu_group"
        name="Medical Equipment"
        sequence="6"/>

    <menuitem
        id="provisional_order_menu"
        name="Provisional Orders"
        action="medical_equipment_action"
        parent="medical_equipment_menu"
        sequence="0"/>
    
    <menuitem
        id="medical_equipment_operation_menu"
        name="Operations"
        action="donaiton_box_operation_action"
        parent="medical_equipment_menu"
        sequence="2"/>

</odoo>
