<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_form_inherit_mr" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.material.request</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='requisition_id']" position="after">
                <field name="material_request_id" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_order_tree_inherit_mr" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit.material.request</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="material_request_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>